/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

.notice-dialog-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(18, 27, 46, 0.46);
}

.notice-dialog-card {
  width: 100%;
  max-width: 680rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 24rpx 60rpx rgba(18, 38, 84, 0.22);
  overflow: hidden;
}

.notice-dialog-title {
  padding: 30rpx 34rpx 18rpx;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1b2740;
  text-align: center;
}

.notice-dialog-scroll {
  height: 440rpx;
  padding: 0 32rpx 24rpx;
  box-sizing: border-box;
}

.notice-dialog-content {
  min-height: 100%;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f8ff;
  font-size: 33rpx;
  line-height: 1.9;
  color: #4e5f7f;
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: anywhere;
  box-sizing: border-box;
}

.notice-dialog-btn {
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #4d76ff 0%, #315fe3 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.notice-dialog-btn::after {
  border: none;
}
