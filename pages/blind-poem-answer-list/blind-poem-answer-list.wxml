<view class="page">
  <view class="section-card" wx:if="{{loading}}">
    <view class="page-title">作品记录</view>
    <view class="page-desc">正在加载作品记录...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="page-title">加载失败</view>
    <view class="page-desc">{{errorMessage}}</view>
    <button class="action-btn" bindtap="loadAnswerList">重新加载</button>
  </view>

  <block wx:else>
    <view class="section-card">
      <view class="page-title">作品记录</view>
      <view class="page-desc">这里按紧凑列表展示作品记录，方便快速屏蔽与精选。</view>
      <view class="mode-tab-row">
        <view
          class="mode-tab {{activeFilter === item.value ? 'mode-tab-active' : ''}}"
          wx:for="{{filterOptions}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="onFilterChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="dense-list" wx:if="{{filteredAnswerList.length}}">
      <view class="dense-item" wx:for="{{filteredAnswerList}}" wx:key="answerId">
        <view class="dense-main">
          <view class="dense-top">
            <view class="dense-title">{{item.promptSummary}}</view>
            <view class="answer-tag-row">
              <view class="prompt-status {{item.reviewStatus}}">{{item.reviewStatusText}}</view>
              <view class="prompt-status featured" wx:if="{{item.isFeatured}}">精选</view>
            </view>
          </view>
          <view class="dense-desc">{{item.content}}</view>
          <view class="dense-meta">{{item.modeText}} · {{item.authorText}} · {{item.createdAtText}}</view>
        </view>

        <view class="dense-actions">
          <view
            class="mini-btn {{updatingAnswerId === item.answerId ? 'mini-btn-disabled' : ''}}"
            bindtap="onToggleAnswerBlockTap"
            data-answer="{{item}}"
          >
            {{item.reviewStatus === 'blocked' ? '取消屏蔽' : '屏蔽'}}
          </view>
          <view
            class="mini-btn light {{updatingAnswerId === item.answerId || item.reviewStatus === 'blocked' ? 'mini-btn-disabled' : ''}}"
            bindtap="onToggleAnswerFeatureTap"
            data-answer="{{item}}"
          >
            {{item.isFeatured ? '取消精选' : '精选'}}
          </view>
        </view>
      </view>
    </view>

    <view class="section-card" wx:else>
      <view class="page-desc">当前筛选下还没有作品记录。</view>
    </view>
  </block>
</view>
