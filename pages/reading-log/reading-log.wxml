<view class="page">
  <view class="header-card">
    <view class="page-title">阅读打卡</view>
    <view class="page-desc">{{pageDesc}}</view>
  </view>

  <view class="section-card">
    <view class="section-title">打卡信息</view>

    <view class="form-item">
      <view class="label">书名</view>
      <input
        class="input"
        placeholder-class="field-placeholder"
        placeholder="请输入书名"
        value="{{form.bookTitle}}"
        bindinput="onBookTitleInput"
      />
    </view>

    <view class="form-item">
      <view class="label">作者（选填）</view>
      <input
        class="input"
        placeholder-class="field-placeholder"
        placeholder="请输入作者"
        value="{{form.author}}"
        bindinput="onAuthorInput"
      />
    </view>

    <view class="form-item">
      <view class="label">阅读时长（分钟）</view>
      <input
        class="input"
        type="number"
        placeholder-class="field-placeholder"
        placeholder="例如：45"
        value="{{form.duration}}"
        bindinput="onDurationInput"
      />
    </view>

    <view class="form-item">
      <view class="label">阅读页数 / 章节（选填）</view>
      <input
        class="input"
        placeholder-class="field-placeholder"
        placeholder="例如：第20-35页 / 第3章"
        value="{{form.pagesOrChapter}}"
        bindinput="onPagesOrChapterInput"
      />
    </view>

    <view class="form-item">
      <view class="label">关联活动（默认当前激励活动）</view>
      <picker
        mode="selector"
        range="{{activityTitleOptions}}"
        value="{{form.activityIndex}}"
        bindchange="onActivityChange"
      >
        <view class="picker-field {{form.activityId ? '' : 'picker-placeholder'}}">{{form.activityTitle || '不关联活动'}}</view>
      </picker>
      <view class="picker-hint" wx:if="{{activitiesLoading}}">活动列表加载中...</view>
      <view class="picker-hint" wx:else>{{activityHintText}}</view>
    </view>

    <view class="form-item">
      <view class="label">内容标题（选填）</view>
      <input
        class="input"
        placeholder-class="field-placeholder"
        placeholder="给这次阅读内容起一个小标题"
        value="{{form.contentTitle}}"
        bindinput="onContentTitleInput"
      />
    </view>

    <view class="form-item">
      <view class="label">一句话感悟（与摘抄二选一必填）</view>
      <textarea
        class="textarea"
        placeholder-class="field-placeholder"
        placeholder="写一句你今天最想记下来的感受"
        value="{{form.insight}}"
        bindinput="onInsightInput"
        maxlength="100"
      />
    </view>

    <view class="form-item">
      <view class="label">摘抄内容（与感悟二选一必填）</view>
      <textarea
        class="textarea"
        placeholder-class="field-placeholder"
        placeholder="记录一句想保存下来的文字"
        value="{{form.excerpt}}"
        bindinput="onExcerptInput"
        maxlength="200"
      />
    </view>

    <button class="submit-btn" bindtap="onSubmit" disabled="{{loading}}">
      {{loading ? '提交中...' : '完成打卡'}}
    </button>
  </view>

  <view class="poster-dialog-mask" wx:if="{{posterPromptVisible}}" catchtouchmove="noop">
    <view class="poster-dialog" catchtap="noop">
      <view class="poster-dialog-title">{{posterPromptTitle}}</view>
      <view class="poster-dialog-content">{{posterPromptContent}}</view>
      <view class="poster-dialog-actions">
        <view class="poster-dialog-btn poster-dialog-btn-secondary" bindtap="onPosterPromptCancel">取消</view>
        <view class="poster-dialog-btn poster-dialog-btn-primary" bindtap="onPosterPromptConfirm">去制作海报</view>
      </view>
    </view>
  </view>
</view>
