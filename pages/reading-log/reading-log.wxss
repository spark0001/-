.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 14rpx;
}

.page-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #222222;
}

.input {
  height: 96rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 24rpx;
}

.field-placeholder {
  font-size: 28rpx;
  line-height: 1.6;
  color: #a0a7b4;
}

.picker-field {
  width: 100%;
  min-height: 88rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #222222;
}

.picker-placeholder {
  color: #999999;
}

.picker-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b93a1;
}

.submit-btn {
  margin-top: 12rpx;
  background: #222222;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
}

button::after {
  border: none;
}

.poster-dialog-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.42);
}

.poster-dialog {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 34rpx 28rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 48rpx rgba(15, 23, 42, 0.18);
}

.poster-dialog-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #1f2937;
  text-align: center;
}

.poster-dialog-content {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #667085;
  text-align: center;
}

.poster-dialog-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.poster-dialog-btn {
  flex: 1;
  min-height: 92rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.poster-dialog-btn-secondary {
  background: #f3f4f6;
  color: #475467;
}

.poster-dialog-btn-primary {
  background: linear-gradient(135deg, #1d74ff 0%, #4b8cff 100%);
  color: #ffffff;
}
