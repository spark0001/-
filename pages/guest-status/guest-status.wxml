<view class="page">
  <view class="header-card">
    <view class="page-title">报名参与读书会活动</view>
    <view class="page-desc">当前仅展示报名状态与活动介绍，审核通过后才可进入首页和创作互动功能。</view>
  </view>

  <view class="section-card" wx:if="{{loading}}">
    <view class="section-title">报名状态</view>
    <view class="section-text">正在加载报名状态...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="section-text">{{errorMessage}}</view>
  </view>

  <block wx:else>
    <view class="section-card">
      <view class="section-header">
        <view class="section-title">报名状态</view>
        <view class="status-badge {{statusClass}}">{{statusText}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">姓名</view>
        <view class="info-value">{{name || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">年级 / 专业</view>
        <view class="info-value">{{gradeMajor || '未填写'}}</view>
      </view>

      <view class="info-row no-border">
        <view class="info-label">提交时间</view>
        <view class="info-value">{{createdAtText}}</view>
      </view>

      <view class="status-button disabled">{{statusButtonText}}</view>
    </view>

    <view class="section-card">
      <view class="section-title">读书会介绍</view>
      <view class="section-text">
        我们围绕阅读、分享、线下交流与创意互动开展活动，审核通过后可正式进入小程序参与活动与互动。
      </view>
    </view>

    <view class="section-card">
      <view class="section-title">近期活动</view>
      <view class="activity-item">本月主题阅读：女性写作</view>
      <view class="activity-item">线下分享会：小说人物讨论</view>
      <view class="activity-item">创意互动：双盲作诗体验</view>
    </view>
  </block>

  <view class="notice-dialog-mask" wx:if="{{noticePromptVisible}}" catchtouchmove="noop">
    <view class="notice-dialog-card" catchtap="noop">
      <view class="notice-dialog-title">{{noticePromptTitle || '公告'}}</view>
      <scroll-view class="notice-dialog-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="notice-dialog-content">{{noticePromptContent}}</view>
      </scroll-view>
      <button class="notice-dialog-btn" bindtap="onNoticePromptConfirm">我知道了</button>
    </view>
  </view>
</view>
