.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 16rpx;
}

.page-desc,
.section-text,
.info-value {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.status-badge.pending {
  background: #fff4e5;
  color: #a15c00;
}

.status-badge.approved {
  background: #e8f7ef;
  color: #1f8f55;
}

.status-badge.rejected {
  background: #fdecec;
  color: #b42318;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row.no-border {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
}

.status-button {
  margin-top: 20rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
}

.status-button.disabled {
  background: #f1f2f6;
  color: #8a8f98;
}

.activity-item {
  font-size: 28rpx;
  color: #444444;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}
