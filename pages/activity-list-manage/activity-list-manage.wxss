.page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 140rpx;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.14), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.16), transparent 28%),
    linear-gradient(180deg, #f5f8ff 0%, #f6f8fc 34%, #f5f7fb 100%);
  box-sizing: border-box;
}

.section-card {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(143, 182, 255, 0.56) 100%) top/100% 8rpx no-repeat,
    rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(218, 229, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
  backdrop-filter: blur(12rpx);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #17306a;
  font-weight: 700;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f2f7ff 0%, #e2eeff 100%);
  border: 1rpx solid #d7e4ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.section-link {
  font-size: 24rpx;
  color: #8a95a7;
}

.page-desc {
  font-size: 26rpx;
  line-height: 1.8;
  color: #66758d;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.filter-chip {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f5f8ff 0%, #edf2fb 100%);
  color: #6e7c93;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
  border: 1rpx solid #e1e9f7;
}

.filter-chip.active {
  background: linear-gradient(135deg, #4d76ff 0%, #2f5eed 100%);
  color: #ffffff;
  border-color: transparent;
  box-shadow: 0 12rpx 22rpx rgba(77, 118, 255, 0.2);
}

.activity-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8ff 100%);
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #e0eaff;
  box-shadow: 0 12rpx 24rpx rgba(44, 74, 155, 0.06);
}

.activity-card:last-child {
  margin-bottom: 0;
}

.activity-card.compact {
  padding: 20rpx;
}

.activity-card-accent {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #7ea3ff 55%, rgba(126, 163, 255, 0.16) 100%);
}

.activity-cover-thumb {
  width: 100%;
  height: 200rpx;
  border-radius: 18rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f7faff 100%);
}

.activity-cover-thumb.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #eef4ff 0%, #f8fbff 100%);
  color: #9ba8bc;
  font-size: 28rpx;
}

.activity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.activity-title {
  flex: 1;
  min-width: 0;
  font-size: 31rpx;
  font-weight: 700;
  color: #16233f;
  line-height: 1.5;
}

.activity-mode-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 600;
}

.activity-mode-tag.offline {
  background: #eef6ff;
  color: #2f5fcd;
}

.activity-mode-tag.online {
  background: #eef3fb;
  color: #66758d;
}

.activity-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.activity-mini-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(240, 245, 255, 0.96);
  color: #6b7a94;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid #e0e8f7;
}

.activity-info {
  font-size: 26rpx;
  color: #6b7890;
  margin-bottom: 6rpx;
  line-height: 1.6;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  background: linear-gradient(135deg, #4d76ff 0%, #2f5eed 100%);
  color: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 22rpx rgba(77, 118, 255, 0.16);
}

.action-btn.light {
  background: linear-gradient(180deg, #f3f7ff 0%, #e9f1ff 100%);
  color: #3559c7;
  border: 1rpx solid #d8e5ff;
  box-shadow: none;
}

.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b7890;
}

.hero-card {
  background:
    radial-gradient(circle at top right, rgba(77, 118, 255, 0.16), transparent 28%),
    radial-gradient(circle at top left, rgba(143, 182, 255, 0.16), transparent 30%),
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(143, 182, 255, 0.56) 100%) top/100% 8rpx no-repeat,
    linear-gradient(135deg, rgba(236, 243, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 52%, rgba(244, 248, 255, 0.98) 100%);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.4rpx;
}

.plain-title {
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  font-size: 48rpx;
  font-weight: 800;
  color: #15213d;
}

.hero-header {
  margin-bottom: 0;
}

.header-status {
  flex-shrink: 0;
  margin-top: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.header-status.is-ready {
  background: rgba(77, 118, 255, 0.12);
  color: #3f68ea;
}

.header-status.is-loading {
  background: rgba(240, 246, 255, 0.96);
  color: #7b8db3;
}

.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(220, 231, 250, 0.95);
  color: #5d6d88;
  font-size: 23rpx;
  font-weight: 600;
}

.sync-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7f99;
}

.sync-tip.error {
  color: #b45309;
}

.error-card .plain-title {
  color: #b42318;
}

button::after {
  border: none;
}
