.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.history-prompt,
.history-status,
.history-time {
  font-size: 26rpx;
  line-height: 1.7;
  color: #666666;
}

.history-card {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.history-card:last-child {
  margin-bottom: 0;
}

.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.history-mode {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
}

.history-content,
.history-result {
  font-size: 28rpx;
  line-height: 1.8;
  color: #222222;
  margin-top: 12rpx;
  white-space: pre-wrap;
}

.history-result {
  color: #3559c7;
}
