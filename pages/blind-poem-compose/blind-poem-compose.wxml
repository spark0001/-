<view class="page">
  <view class="section-card" wx:if="{{loading}}">
    <view class="page-title">正在生成题面</view>
    <view class="page-desc">请稍等，系统正在为你准备这一轮双盲作诗。</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="page-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <block wx:else>
    <view class="section-card">
      <view class="page-title">{{modeText}}</view>
      <view class="page-desc">{{promptTitle}}</view>

      <view class="prompt-box">
        <view class="prompt-meta" wx:if="{{roleText}}">{{roleText}}</view>
        <view class="prompt-text">{{promptText}}</view>
        <view class="prompt-meta" wx:if="{{theme}}">主题：{{theme}}</view>
        <view class="prompt-meta" wx:if="{{imageryText}}">意象：{{imageryText}}</view>
      </view>
    </view>

    <view class="section-card">
      <view class="field-label">写下你的作品</view>
      <textarea
        class="field-textarea"
        maxlength="120"
        value="{{content}}"
        bindinput="onInput"
        placeholder="请在这里写下你的短诗或诗句"
      ></textarea>
      <view class="count-text">当前字数：{{contentCount}} / 120</view>

      <button class="submit-btn" bindtap="onSubmitTap" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '提交作品'}}
      </button>
    </view>
  </block>
</view>
