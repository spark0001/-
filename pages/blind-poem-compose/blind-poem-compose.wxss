.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.prompt-text,
.prompt-meta,
.count-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #666666;
}

.prompt-box {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.prompt-meta {
  margin-top: 12rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 16rpx;
}

.field-textarea {
  width: 100%;
  min-height: 320rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #222222;
}

.count-text {
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 24rpx;
  border-radius: 18rpx;
  background: #222222;
  color: #ffffff;
  font-size: 28rpx;
}

button::after {
  border: none;
}
