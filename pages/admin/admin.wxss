.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.14), transparent 32%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.18), transparent 28%),
    linear-gradient(180deg, #f4f8ff 0%, #f6f8fc 34%, #f5f7fb 100%);
  padding: 24rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(139, 178, 255, 0.48) 100%) top/100% 8rpx no-repeat,
    rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(218, 229, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
  backdrop-filter: blur(12rpx);
}

.header-card {
  background:
    radial-gradient(circle at top right, rgba(77, 118, 255, 0.16), transparent 28%),
    radial-gradient(circle at top left, rgba(143, 182, 255, 0.16), transparent 30%),
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(139, 178, 255, 0.48) 100%) top/100% 8rpx no-repeat,
    linear-gradient(135deg, rgba(236, 243, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 52%, rgba(244, 248, 255, 0.98) 100%);
}

.page-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #15213d;
  margin-bottom: 16rpx;
  letter-spacing: 0.8rpx;
}

.page-desc {
  max-width: 620rpx;
  font-size: 28rpx;
  line-height: 1.85;
  color: #5f6b83;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
}

.status-badge.approved {
  background: rgba(77, 118, 255, 0.12);
  color: #3f68ea;
  border: 1rpx solid rgba(77, 118, 255, 0.18);
}

.status-badge.neutral {
  background: #eef2f7;
  color: #667085;
}

.status-badge.light {
  background: rgba(232, 240, 255, 0.9);
  color: #5e6f8d;
  border: 1rpx solid rgba(210, 223, 250, 0.95);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #17306a;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f2f7ff 0%, #e2eeff 100%);
  border: 1rpx solid #d7e4ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  margin-bottom: 22rpx;
  box-sizing: border-box;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-link {
  font-size: 24rpx;
  color: #8b95a7;
}

.section-link.clickable-link {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #4d76ff;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(242, 247, 255, 0.95) 0%, rgba(231, 239, 255, 0.98) 100%);
  border: 1rpx solid rgba(216, 228, 255, 0.95);
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #1f2f57;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.label-required {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #8b97a9;
}

.label-optional {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #8b97a9;
  font-weight: 400;
}

.input,
.textarea {
  width: 100%;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7ff 100%);
  border-radius: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1e2a44;
  border: 1rpx solid #dfe9ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.input {
  height: 104rpx;
  line-height: 104rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  padding: 28rpx 24rpx;
  line-height: 1.7;
}

.picker-group {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.picker-item {
  flex: 1;
}

.picker-label {
  font-size: 26rpx;
  color: #304262;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.picker-field {
  min-height: 104rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7ff 100%);
  border-radius: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2d49;
  display: flex;
  align-items: center;
  border: 1rpx solid #dfe9ff;
}

.picker-placeholder {
  color: #9aa5b6;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #dfebff;
}

.switch-text {
  font-size: 28rpx;
  color: #203153;
  font-weight: 700;
}

.time-preview,
.cover-tip {
  font-size: 26rpx;
  line-height: 1.8;
  color: #60708b;
}

.template-tip {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #6c7b94;
}

.template-meta-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6d7b94;
}

.template-meta-text.no-margin {
  margin-top: 0;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 16rpx;
}

.section-subtitle.no-margin {
  margin-bottom: 0;
}

.section-subtitle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.section-toggle {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #667085;
}

.small-btn {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.template-editor-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8ff 100%);
  border-radius: 22rpx;
  border: 1rpx solid #e0eaff;
}

.template1-thumb-editor {
  width: 200rpx;
  height: 200rpx;
  margin-top: 16rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #eef4ff;
  border: 1rpx solid #dbe6fb;
  box-shadow: 0 10rpx 22rpx rgba(77, 118, 255, 0.08);
}

.template1-thumb-editor-image {
  width: 100%;
  height: 100%;
}

.compact-row {
  margin-top: 16rpx;
}

.template2-editor-board {
  position: relative;
  width: 560rpx;
  height: 315rpx;
  margin: 20rpx auto 0;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #dbe6fb;
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.28),
    0 12rpx 28rpx rgba(77, 118, 255, 0.08);
}

.template2-editor-board.white-board {
  background: #ffffff;
}

.template2-editor-area {
  width: 100%;
  height: 100%;
}

.template2-editor-movable {
  z-index: 1;
}

.template2-editor-movable-text {
  z-index: 3;
}

.template2-editor-movable-image {
  z-index: 2;
}

.template2-editor-movable-shape {
  z-index: 1;
}

.template2-preview-text-field {
  position: absolute;
  z-index: 3;
  line-height: 1.6;
  word-break: break-all;
  box-sizing: border-box;
  white-space: pre-wrap;
}

.template2-preview-badge {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  z-index: 4;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #3559c7;
  font-size: 22rpx;
  line-height: 1.2;
}

.template2-preview-text {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
}

.template2-preview-title {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: inherit;
  margin-bottom: 10rpx;
}

.template2-preview-info {
  font-size: 22rpx;
  line-height: 1.6;
  color: inherit;
  opacity: 0.9;
  margin-bottom: 6rpx;
}

.template2-preview-info:last-child {
  margin-bottom: 0;
}

.template2-preview-image {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.3);
}

.template2-preview-shape {
  box-sizing: border-box;
}

.template2-preview-shape-circle {
  border-radius: 50%;
}

.template2-preview-shape-star {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.template2-preview-shape-triangle {
  width: 0;
  height: 0;
}

.template-element-panel {
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid #dfebff;
}

.template3-panel {
  border-radius: 20rpx;
}

.template-element-preview,
.template-element-placeholder {
  width: 100%;
  height: 220rpx;
}

.template-element-preview.template3-preview,
.template-element-placeholder.template3-preview {
  height: 315rpx;
}

.template-element-placeholder.square {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
}

.template-element-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 26rpx;
  background: linear-gradient(135deg, #eef2f7 0%, #f8fafc 100%);
}

.shape-editor-card {
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e0eaff;
}

.shape-editor-card:last-child {
  margin-bottom: 0;
}

.shape-editor-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.picker-item.full-width {
  width: 100%;
}

.shape-editor-title {
  font-size: 27rpx;
  font-weight: 600;
  color: #222222;
}

.shape-color-preview-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.shape-color-chip {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.shape-color-value {
  font-size: 24rpx;
  line-height: 1.6;
  color: #667085;
  word-break: break-all;
}

.shape-editor-remove {
  font-size: 24rpx;
  color: #b42318;
}

.form-item.tight {
  margin-bottom: 16rpx;
}

.cover-panel {
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 1rpx solid #deebff;
}

.cover-preview,
.cover-placeholder {
  width: 100%;
  height: 320rpx;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999999;
  font-size: 28rpx;
  background: linear-gradient(135deg, #eef4ff 0%, #f8fbff 100%);
}

.submit-action-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #4d76ff 0%, #2f5eed 100%);
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(77, 118, 255, 0.22);
}

.duplicate-btn {
  background: linear-gradient(180deg, #edf3ff 0%, #dfeaff 100%);
  color: #2f5eed;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 1rpx solid #cadcff;
  box-shadow: 0 10rpx 20rpx rgba(77, 118, 255, 0.12);
}

.secondary-btn {
  background: linear-gradient(180deg, #f3f7ff 0%, #e9f1ff 100%);
  color: #3559c7;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid #d8e5ff;
}

.submit-action-group .submit-btn,
.submit-action-group .duplicate-btn,
.submit-action-group .secondary-btn {
  width: 100%;
  margin-top: 0;
}

.activity-card {
  background:
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(139, 178, 255, 0.58) 8rpx, transparent 8rpx) top left/100% 100% no-repeat,
    linear-gradient(180deg, #fbfdff 0%, #f5f8ff 100%);
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #e0eaff;
  box-shadow: 0 12rpx 24rpx rgba(44, 74, 155, 0.06);
}

.activity-card:last-child {
  margin-bottom: 0;
}

.activity-cover-thumb {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.activity-cover-thumb.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #eef2f7 0%, #f8fafc 100%);
  color: #999999;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17233d;
  margin-bottom: 12rpx;
}

.activity-info {
  font-size: 26rpx;
  color: #67758d;
  margin-bottom: 6rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  background: linear-gradient(135deg, #4d76ff 0%, #2f5eed 100%);
  color: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 22rpx rgba(77, 118, 255, 0.16);
}

.action-btn.light {
  background: linear-gradient(180deg, #f3f7ff 0%, #e9f1ff 100%);
  color: #3559c7;
  border: 1rpx solid #d7e4ff;
  box-shadow: none;
}

.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6a7890;
}

button::after {
  border: none;
}
