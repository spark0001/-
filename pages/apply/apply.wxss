.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 16rpx;
}

.page-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 20rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.activity-item {
  font-size: 28rpx;
  color: #444444;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-item:last-child {
  border-bottom: none;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.input,
.textarea {
  width: 100%;
  background: #f7f8fa;
  border-radius: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #222222;
}

.input {
  height: 100rpx;
  line-height: 100rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 220rpx;
  line-height: 1.7;
  padding: 28rpx 24rpx;
}

.submit-btn {
  margin-top: 12rpx;
  background: #222222;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
}
