<view class="page">
  <view class="header-card" wx:if="{{loading}}">
    <view class="page-title">我的所有打卡记录</view>
    <view class="page-desc">正在加载你发布过的阅读打卡和生活分享...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="onRetryTap">重新加载</button>
  </view>

  <block wx:else>
    <view class="header-card">
      <view class="page-title">我的所有打卡记录</view>
      <view class="page-desc">按时间倒序展示你的阅读打卡和生活分享。</view>
    </view>

    <view class="section-card" wx:if="{{recordList.length}}">
      <view class="record-card" wx:for="{{recordList}}" wx:key="recordKey" data-index="{{index}}" bindtap="goRecordDetail">
        <view class="record-main">
          <view class="record-top">
            <view class="record-tag {{item.typeClass}}">{{item.typeText}}</view>
            <view class="record-time">{{item.createdAtText}}</view>
          </view>
          <view class="record-title">{{item.title}}</view>
          <view class="record-summary" wx:if="{{item.summary}}">{{item.summary}}</view>
          <view class="record-actions">
            <view class="record-enter-text">点击查看详情</view>
            <view class="record-edit-btn" data-index="{{index}}" catchtap="onEditRecordTap">编辑</view>
          </view>
        </view>
        <image class="record-thumb" wx:if="{{item.hasImage}}" src="{{item.imageUrl}}" mode="aspectFill"></image>
      </view>
    </view>

    <view class="section-card" wx:else>
      <view class="empty-text">你还没有发布过阅读打卡或生活分享。</view>
    </view>
  </block>
</view>
