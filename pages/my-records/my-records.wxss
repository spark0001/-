.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.record-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.record-card:last-child {
  margin-bottom: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.record-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.record-tag.reading {
  background: #eef3ff;
  color: #3559c7;
}

.record-tag.life {
  background: #edf8f1;
  color: #157347;
}

.record-time {
  font-size: 23rpx;
  line-height: 1.6;
  color: #8b93a1;
  text-align: right;
}

.record-title {
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #222222;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-summary {
  font-size: 26rpx;
  line-height: 1.7;
  color: #555555;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.record-enter-text {
  font-size: 23rpx;
  line-height: 1.6;
  color: #8b93a1;
}

.record-edit-btn {
  flex-shrink: 0;
  min-width: 112rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #1d4ed8;
  background: linear-gradient(135deg, #edf5ff 0%, #dce9ff 100%);
  border: 1rpx solid #d8e5ff;
}

.record-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #e9edf3;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
  border-radius: 16rpx;
  font-size: 28rpx;
}

button::after {
  border: none;
}
