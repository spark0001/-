.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card,
.editor-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.crop-shell {
  position: relative;
  margin: 0 auto;
  overflow: hidden;
  background: #eef1f5;
  touch-action: none;
}

.crop-shell-circle {
  border-radius: 50%;
}

.crop-shell-rect {
  border-radius: 24rpx;
}

.editor-image {
  position: absolute;
}

.crop-frame {
  position: absolute;
  inset: 0;
  border: 4rpx dashed rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  pointer-events: none;
}

.crop-frame-circle {
  border-radius: 50%;
}

.crop-frame-rect {
  border-radius: 24rpx;
}

.slider-row {
  margin-top: 28rpx;
}

.slider-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.primary-btn,
.secondary-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.primary-btn {
  background: #222222;
  color: #ffffff;
}

.secondary-btn {
  background: #f1f2f6;
  color: #333333;
}

.crop-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

button::after {
  border: none;
}
