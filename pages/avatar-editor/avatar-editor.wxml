<view class="page">
  <view class="header-card">
    <view class="page-title">{{pageTitleText}}</view>
    <view class="page-desc">{{pageDescText}}</view>
  </view>

  <view class="section-card" wx:if="{{errorMessage}}">
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="onCancel">返回</button>
  </view>

  <block wx:else>
    <view class="editor-card">
      <view
        class="crop-shell {{cropShape === 'circle' ? 'crop-shell-circle' : 'crop-shell-rect'}}"
        style="width: {{cropWidth}}px; height: {{cropHeight}}px;"
        bindtouchstart="onCropTouchStart"
        catchtouchmove="onCropTouchMove"
        bindtouchend="onCropTouchEnd"
        bindtouchcancel="onCropTouchEnd"
      >
        <image class="editor-image" src="{{imagePath}}" mode="aspectFill" style="{{imageStyle}}"></image>
        <view class="crop-frame {{cropShape === 'circle' ? 'crop-frame-circle' : 'crop-frame-rect'}}"></view>
      </view>

      <view class="slider-row">
        <view class="slider-label">缩放图片</view>
        <slider
          min="{{minScalePercent}}"
          max="{{maxScalePercent}}"
          step="1"
          value="{{scalePercent}}"
          show-value
          activeColor="#222222"
          backgroundColor="#d9dee8"
          block-color="#222222"
          bindchanging="onScaleChange"
          bindchange="onScaleChange"
        />
      </view>
    </view>

    <view class="action-row">
      <button class="secondary-btn" bindtap="onCancel" disabled="{{saving}}">取消</button>
      <button class="primary-btn" bindtap="onSaveImage" disabled="{{saving || !ready}}">
        {{saving ? '保存中...' : saveButtonText}}
      </button>
    </view>
  </block>

  <canvas
    canvas-id="avatarCropCanvas"
    class="crop-canvas"
    style="width: {{outputWidth}}px; height: {{outputHeight}}px;"
  ></canvas>
</view>
