.page {
  padding: 24rpx;
  padding-bottom: 140rpx;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.14), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.16), transparent 30%),
    linear-gradient(180deg, #f5f8ff 0%, #f6f8fc 32%, #f5f7fb 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.section-card {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(143, 182, 255, 0.58) 100%) top/100% 8rpx no-repeat,
    rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(218, 229, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
  backdrop-filter: blur(12rpx);
}

.page-title,
.section-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #15213d;
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #17306a;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #f2f7ff 0%, #e2eeff 100%);
  border: 1rpx solid #d7e4ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.page-desc {
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #66758d;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.section-link {
  margin-top: -8rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #4d76ff;
  font-weight: 600;
}

.section-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #e2eeff 100%);
  color: #3f68ea;
  font-size: 22rpx;
  font-weight: 600;
}

.form-item {
  margin-bottom: 28rpx;
}

.label,
.switch-label {
  font-size: 27rpx;
  color: #203153;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #16233f;
  box-sizing: border-box;
  border: 1rpx solid #dfe9ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.textarea {
  min-height: 240rpx;
  line-height: 1.7;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e0eaff;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8ff 100%);
  margin-bottom: 16rpx;
}

.switch-row:last-of-type {
  border-bottom: none;
}

.switch-copy {
  flex: 1;
  min-width: 0;
}

.switch-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #75839b;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-row.compact {
  margin-top: 18rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #4d76ff 0%, #2f5eed 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 16rpx 30rpx rgba(77, 118, 255, 0.2);
}

.action-btn.light {
  background: linear-gradient(180deg, #f3f7ff 0%, #e9f1ff 100%);
  color: #3559c7;
  box-shadow: none;
  border: 1rpx solid #d9e5ff;
}

.prompt-card {
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  padding: 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e0eaff;
}

.overview-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.overview-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(90deg, rgba(77, 118, 255, 0.92) 0%, rgba(143, 182, 255, 0.62) 6rpx, transparent 6rpx) top left/100% 100% no-repeat,
    linear-gradient(180deg, #fbfdff 0%, #f5f8ff 100%);
  border: 1rpx solid #e0eaff;
}

.overview-main {
  flex: 1;
  min-width: 0;
}

.overview-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.overview-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 700;
  color: #16233f;
}

.overview-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #58657d;
}

.overview-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a0b3;
}

.prompt-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.answer-tag-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.prompt-mode {
  font-size: 24rpx;
  font-weight: 600;
  color: #4338ca;
}

.prompt-status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.prompt-status.enabled {
  background: #dcfce7;
  color: #15803d;
}

.prompt-status.disabled {
  background: #f3f4f6;
  color: #6b7280;
}

.prompt-status.blocked {
  background: #fee2e2;
  color: #b91c1c;
}

.prompt-status.normal {
  background: #dcfce7;
  color: #15803d;
}

.prompt-status.featured {
  background: #fef3c7;
  color: #b45309;
}

.prompt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.prompt-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
}

.prompt-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.4rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.header-status {
  flex-shrink: 0;
  margin-top: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.header-status.is-ready {
  background: rgba(77, 118, 255, 0.12);
  color: #3f68ea;
}

.header-status.is-loading {
  background: rgba(240, 246, 255, 0.96);
  color: #7b8db3;
}

.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.hero-meta-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(220, 231, 250, 0.95);
  color: #5d6d88;
  font-size: 23rpx;
  font-weight: 600;
}

.sync-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7f99;
}

.sync-tip.error {
  color: #b45309;
}

.section-subtitle {
  margin-top: -8rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #75839b;
}

.error-card .page-title {
  color: #b42318;
}

.field-placeholder {
  color: #a8b1c1;
  line-height: 1.7;
}

.input {
  min-height: 108rpx;
  display: flex;
  align-items: center;
}

button::after {
  border: none;
}
