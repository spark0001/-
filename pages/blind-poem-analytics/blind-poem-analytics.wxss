.page {
  padding: 24rpx;
  background: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.page-title,
.section-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2937;
}

.section-title {
  font-size: 32rpx;
}

.page-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #111827;
}

.stat-label,
.rate-text,
.funnel-label,
.funnel-value,
.mode-meta {
  font-size: 24rpx;
  color: #6b7280;
}

.rate-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.funnel-list {
  margin-top: 18rpx;
}

.funnel-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.funnel-item:last-child {
  margin-bottom: 0;
}

.funnel-label {
  width: 150rpx;
  flex-shrink: 0;
}

.funnel-bar-shell {
  flex: 1;
  height: 28rpx;
  background: #eef2f7;
  border-radius: 999rpx;
  overflow: hidden;
}

.funnel-bar {
  height: 100%;
  border-radius: 999rpx;
}

.funnel-bar.stage-1 {
  background: #2f6df6;
}

.funnel-bar.stage-2 {
  background: #4d76ff;
}

.funnel-bar.stage-3 {
  background: #7ea0ff;
}

.funnel-value {
  width: 80rpx;
  text-align: right;
  color: #111827;
}

.mode-card {
  margin-top: 16rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.mode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.action-btn {
  margin-top: 20rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #222222;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
}

button::after {
  border: none;
}
