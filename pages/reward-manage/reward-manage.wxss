.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.member-meta,
.activity-meta {
  font-size: 26rpx;
  line-height: 1.7;
  color: #666666;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.picker-block {
  margin-top: 20rpx;
}

.rule-summary-block {
  background: #f6f9ff;
  border: 1rpx solid #dbe8ff;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  margin-top: 20rpx;
}

.rule-summary-block.pending {
  background: #f8f9fc;
  border-color: #e5e7eb;
}

.rule-summary-title,
.rule-editor-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d4ed8;
  margin-bottom: 10rpx;
}

.rule-editor {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eef2f7;
}

.picker-label {
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.picker-label.no-margin {
  margin-bottom: 0;
}

.picker-field {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #222222;
}

.picker-field-readonly {
  color: #667085;
}

.picker-field-disabled {
  color: #98a2b3;
}

.status-badge,
.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.status-badge.light,
.section-tag {
  background: #f1f2f6;
  color: #333333;
}

.status-badge.approved {
  background: #e8f7ef;
  color: #1f8f55;
}

.status-badge.neutral {
  background: #eef1f5;
  color: #667085;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.choice-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #eef2f7;
  color: #667085;
  font-size: 24rpx;
}

.choice-chip-active {
  background: #1677ff;
  color: #ffffff;
}

.compact-row {
  margin-top: 18rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  background: #222222;
  color: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
}

.action-btn.light {
  background: #f1f2f6;
  color: #333333;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.primary-btn {
  margin-top: 24rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.activity-card,
.member-card {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.activity-card:last-child,
.member-card:last-child {
  margin-bottom: 0;
}

.activity-title,
.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 10rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f1f2f6;
  color: #667085;
  font-size: 24rpx;
}

.filter-chip-active {
  background: #222222;
  color: #ffffff;
}

.member-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.avatar-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-box.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #222222;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rule-field-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.field-block {
  flex: 1;
  min-width: 0;
}

.field-block-grow {
  flex: 1.3;
}

.field-input {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #222222;
}

.switch-row {
  margin-top: 20rpx;
  padding: 20rpx 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

button::after {
  border: none;
}
