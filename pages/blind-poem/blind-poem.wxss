.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.2), transparent 28%),
    radial-gradient(circle at 50% 22%, rgba(120, 164, 255, 0.14), transparent 30%),
    linear-gradient(180deg, #f5f8ff 0%, #f7f9fc 32%, #f5f7fb 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(220, 232, 255, 0.92);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, rgba(229, 239, 255, 0.94) 0%, rgba(255, 255, 255, 0.98) 48%, rgba(239, 247, 255, 0.98) 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(10rpx);
}

.hero-glow-one {
  width: 220rpx;
  height: 220rpx;
  right: -36rpx;
  top: -40rpx;
  background: rgba(77, 118, 255, 0.16);
}

.hero-glow-two {
  width: 150rpx;
  height: 150rpx;
  right: 120rpx;
  top: 28rpx;
  background: rgba(143, 182, 255, 0.2);
}

.hero-orbit {
  position: absolute;
  border-radius: 50%;
  border: 1rpx solid rgba(130, 168, 255, 0.16);
  pointer-events: none;
}

.hero-orbit-one {
  width: 280rpx;
  height: 280rpx;
  right: -58rpx;
  top: -76rpx;
}

.hero-orbit-two {
  width: 180rpx;
  height: 180rpx;
  right: 76rpx;
  top: 14rpx;
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
}

.page-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 800;
  color: #17233d;
  margin-bottom: 12rpx;
}

.hero-title-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-floating-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(63, 125, 255, 0.18);
}

.page-desc,
.empty-text,
.mode-desc,
.history-prompt,
.history-status {
  font-size: 26rpx;
  line-height: 1.7;
  color: #667892;
}

.page-desc {
  position: relative;
  z-index: 1;
}

.hero-stat-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-stat-card {
  min-height: 118rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(220, 230, 250, 0.94);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  gap: 8rpx;
}

.hero-stat-card-primary {
  background: linear-gradient(135deg, #4d86ff 0%, #315fe3 100%);
  border-color: transparent;
  box-shadow: 0 12rpx 24rpx rgba(63, 125, 255, 0.22);
}

.hero-stat-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #1c345f;
  line-height: 1;
}

.hero-stat-label {
  font-size: 22rpx;
  color: #7082a2;
  font-weight: 600;
}

.hero-stat-card-primary .hero-stat-value,
.hero-stat-card-primary .hero-stat-label {
  color: #ffffff;
}

.hero-badge-row {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(221, 231, 250, 0.94);
  color: #4d5b7a;
  font-size: 22rpx;
  font-weight: 600;
}

.section-header,
.history-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 255, 0.98) 100%);
}

.section-topline {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #8eb6ff 62%, rgba(142, 182, 255, 0.08) 100%);
}

.featured-topline {
  background: linear-gradient(90deg, #ffcf62 0%, #ffd989 58%, rgba(255, 221, 140, 0.18) 100%);
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 196rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 226, 255, 0.94);
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  font-size: 32rpx;
  font-weight: 700;
  color: #22406f;
}

.section-link,
.history-time {
  font-size: 24rpx;
  color: #88acef;
}

.featured-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-card,
.history-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #ffffff 0%, #f7faff 100%);
  border: 1rpx solid #e3edff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 12rpx 26rpx rgba(36, 64, 133, 0.06);
}

.mode-card:last-child,
.history-card:last-child {
  margin-bottom: 0;
}

.mode-card-topline {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #8eb6ff 62%, rgba(142, 182, 255, 0.08) 100%);
}

.mode-card.accent-b .mode-card-topline {
  background: linear-gradient(90deg, #5d8fff 0%, #93c0ff 62%, rgba(147, 192, 255, 0.08) 100%);
}

.mode-card.accent-c .mode-card-topline {
  background: linear-gradient(90deg, #6e9cff 0%, #a9c9ff 62%, rgba(169, 201, 255, 0.08) 100%);
}

.mode-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.mode-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #476ebd;
  font-size: 22rpx;
  font-weight: 700;
}

.mode-accent-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7da5ff 0%, #4d76ff 100%);
  box-shadow: 0 0 0 8rpx rgba(125, 165, 255, 0.12);
}

.mode-title,
.history-mode {
  font-size: 30rpx;
  font-weight: 700;
  color: #182a4a;
  margin-bottom: 10rpx;
}

.mode-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.mode-hint {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8ca0c0;
}

.mode-arrow-pill {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(63, 125, 255, 0.18);
}

.mode-arrow-pill-text {
  font-size: 24rpx;
  font-weight: 700;
}

.mode-arrow-symbol {
  font-size: 26rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.9);
}

.history-prompt {
  margin-bottom: 12rpx;
  color: #6b7f9f;
}

.history-content {
  font-size: 28rpx;
  color: #1f2f4a;
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.history-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.history-status {
  color: #7b8ea9;
}

.history-link {
  font-size: 24rpx;
  line-height: 1.6;
  color: #4d76ff;
  font-weight: 700;
}

.history-card-accent {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, rgba(77, 118, 255, 0.72) 0%, rgba(142, 182, 255, 0.56) 68%, rgba(142, 182, 255, 0.08) 100%);
}

.featured-card {
  background: linear-gradient(180deg, #fffefb 0%, #fffaf2 100%);
  border-color: #fde7ba;
}
