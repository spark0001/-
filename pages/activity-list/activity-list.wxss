.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top, rgba(77, 118, 255, 0.08), transparent 32%),
    #f6f7fb;
  box-sizing: border-box;
}

.section-card,
.activity-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
  margin-bottom: 24rpx;
}

.filter-bar-card {
  display: flex;
  gap: 14rpx;
  padding: 12rpx;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.filter-pill {
  flex: 1;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b7280;
  background: #f3f5fb;
}

.filter-pill-active {
  color: #ffffff;
  background: linear-gradient(135deg, #4d76ff 0%, #2e5cf0 100%);
  box-shadow: 0 10rpx 24rpx rgba(77, 118, 255, 0.28);
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text {
  font-size: 26rpx;
  color: #7b7f8c;
  line-height: 1.7;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.activity-info {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 6rpx;
}

.activity-card {
  position: relative;
  overflow: hidden;
}

.activity-card-topline {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #8fb6ff 65%, rgba(143, 182, 255, 0.12) 100%);
}

.activity-card-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.activity-main {
  flex: 1;
  min-width: 0;
}

.activity-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #eef2f7;
}

.activity-thumb-frame {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #eef2f7;
}

.activity-thumb-image {
  width: 100%;
  height: 100%;
}

.activity-thumb.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b93a1;
  font-size: 26rpx;
  background: linear-gradient(135deg, #eef2f7 0%, #f8fafc 100%);
}

.activity-template2-card,
.activity-template3-card {
  padding: 0;
}

.activity-template2-stage {
  position: relative;
  width: 560rpx;
  height: 315rpx;
  margin: 0 auto;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx dashed #d6dceb;
  background: linear-gradient(180deg, #fbfcff 0%, #f5f7fc 100%);
}

.activity-template3-main {
  margin-top: 18rpx;
}

.activity-template3-image,
.activity-template3-placeholder {
  width: 100%;
  height: 315rpx;
  border-radius: 16rpx;
}

.activity-template3-image {
  display: block;
  background: #eef2f7;
}

.activity-template3-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b93a1;
  font-size: 26rpx;
  background: linear-gradient(135deg, #eef2f7 0%, #f8fafc 100%);
}

.template2-text-field {
  position: absolute;
  z-index: 2;
  line-height: 1.6;
  word-break: break-all;
  box-sizing: border-box;
  white-space: pre-wrap;
}

.template2-image {
  position: absolute;
  z-index: 1;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.3);
}

.template2-shape {
  position: absolute;
  z-index: 0;
  box-sizing: border-box;
}

.template2-shape-circle {
  border-radius: 50%;
}

.template2-shape-star {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.template2-shape-triangle {
  width: 0;
  height: 0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.light-tag {
  background: #f1f2f6;
  color: #666666;
}

.status-tag {
  color: #ffffff;
}

.status-tag-active {
  background: linear-gradient(135deg, #4d76ff 0%, #2e5cf0 100%);
  box-shadow: 0 8rpx 18rpx rgba(77, 118, 255, 0.22);
}

.status-tag-expired {
  background: #222222;
}

.status-tag-scheduled {
  background: #9aa6bf;
}

.action-row {
  display: flex;
  margin-top: 22rpx;
}

.action-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4d76ff 0%, #2e5cf0 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(77, 118, 255, 0.24);
}
