.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(66, 133, 244, 0.16) 0%, rgba(66, 133, 244, 0) 34%),
    linear-gradient(180deg, #eef5ff 0%, #f7f9fd 28%, #f3f5fa 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.section-card {
  background: #ffffff;
  border-radius: 26rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 34rpx rgba(33, 64, 123, 0.08);
}

.hero-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(198, 219, 255, 0.92);
  background: linear-gradient(135deg, #f8fbff 0%, #edf4ff 54%, #ffffff 100%);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(200, 218, 255, 0.92);
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #4f72c7;
  font-weight: 700;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #222222;
  margin: 18rpx 0 14rpx;
}

.page-desc,
.section-desc,
.picker-hint {
  font-size: 27rpx;
  line-height: 1.7;
  color: #667085;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.meta-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(205, 222, 255, 0.92);
  color: #3f5f9f;
  font-size: 22rpx;
  font-weight: 600;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.editor-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid #e8eef9;
  background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
}

.editor-card-topline {
  height: 10rpx;
  margin: -28rpx -28rpx 24rpx;
  background: linear-gradient(90deg, #2f79ff 0%, #79adff 58%, rgba(121, 173, 255, 0.35) 100%);
}

.editor-group {
  margin-bottom: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #e8eefb;
  background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
  box-shadow: 0 8rpx 18rpx rgba(36, 88, 185, 0.04);
}

.editor-group:last-of-type {
  margin-bottom: 0;
}

.editor-group-title {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 0 8rpx 16rpx;
  border-left: 8rpx solid #3b82f6;
  font-size: 28rpx;
  font-weight: 600;
  color: #1d4ed8;
  margin-bottom: 18rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.input,
.textarea,
.picker-field {
  width: 100%;
  background: #ffffff;
  border-radius: 18rpx;
  border: 1rpx solid #dde8fb;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: #222222;
}

.input,
.picker-field {
  min-height: 96rpx;
}

.input {
  display: block;
  height: 96rpx;
  line-height: 96rpx;
}

.textarea {
  display: block;
  min-height: 220rpx;
  padding: 24rpx;
  line-height: 1.7;
}

.textarea-large {
  min-height: 280rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  line-height: 1.5;
}

.field-placeholder,
.picker-placeholder {
  color: #98a2b3;
}

.field-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #8b93a1;
}

.image-action-row {
  display: flex;
}

.image-action-btn {
  min-width: 200rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #eff5ff 0%, #dce9ff 100%);
  color: #1d4ed8;
  border: 1rpx solid #d8e5ff;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1rpx solid #dbe6fb;
  box-shadow: 0 10rpx 18rpx rgba(26, 73, 155, 0.08);
}

.image-thumb {
  width: 100%;
  height: 100%;
  background: #f1f2f6;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.58);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.submit-btn,
.secondary-btn {
  margin-top: 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
}

.primary-submit-btn {
  background: linear-gradient(135deg, #1d74ff 0%, #4b8cff 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 30rpx rgba(22, 119, 255, 0.24);
}

.secondary-btn {
  background: #f1f2f6;
  color: #333333;
}

.image-action-btn::after,
.submit-btn::after,
.secondary-btn::after {
  border: none;
}
