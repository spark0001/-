.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(115, 169, 255, 0.18) 0%, rgba(115, 169, 255, 0) 36%),
    linear-gradient(180deg, #f5f9ff 0%, #f7f9fd 42%, #f3f6fb 100%);
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(214, 227, 255, 0.88);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 18rpx 44rpx rgba(57, 107, 205, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
}

.header-card::before,
.section-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4c8dff 0%, #88bbff 55%, rgba(136, 187, 255, 0) 100%);
}

.detail-hero-card {
  background:
    radial-gradient(circle at top right, rgba(130, 177, 255, 0.2) 0%, rgba(130, 177, 255, 0) 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 250, 255, 0.98) 100%);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(233, 241, 255, 0.92);
  border: 1rpx solid rgba(209, 225, 255, 0.94);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #5d7fc2;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #18253d;
  margin-bottom: 12rpx;
  word-break: break-all;
  white-space: normal;
}

.hero-summary {
  font-size: 27rpx;
  line-height: 1.75;
  color: #6c7f9e;
  margin-bottom: 18rpx;
  word-break: break-all;
  white-space: normal;
}

.page-desc,
.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6c7f9e;
  word-break: break-all;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #22406f;
  margin-bottom: 20rpx;
}

.section-title.plain {
  margin-bottom: 0;
}

.section-header.compact {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.section-tip,
.meta-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #4f77c7;
  background: linear-gradient(135deg, #f1f6ff 0%, #e4efff 100%);
  word-break: break-all;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.type-tag.reading {
  background: #eef3ff;
  color: #3559c7;
}

.type-tag.life {
  background: #edf8f1;
  color: #157347;
}

.type-tag.reward {
  background: #fff1f1;
  color: #d92d20;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.no-border {
  border-bottom: none;
}

.info-label,
.text-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 27rpx;
  line-height: 1.6;
  color: #1f2f4a;
  word-break: break-all;
  white-space: normal;
}

.text-block {
  background: linear-gradient(180deg, #f8fbff 0%, #f1f6ff 100%);
  border: 1rpx solid #e3edff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.text-block.compact {
  padding: 20rpx 24rpx;
}

.text-content {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #324562;
  white-space: pre-wrap;
  word-break: break-all;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.detail-image {
  width: calc((100% - 32rpx) / 3);
  height: 200rpx;
  border-radius: 18rpx;
  background: #e9edf3;
  box-shadow: 0 10rpx 18rpx rgba(66, 102, 166, 0.08);
}

.action-row {
  margin-top: 24rpx;
}

.primary-btn {
  margin-top: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(63, 125, 255, 0.18);
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.secondary-btn::after {
  border: none;
}

.primary-btn::after {
  border: none;
}
