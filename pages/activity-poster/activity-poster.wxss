.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(117, 157, 255, 0.16) 0%, rgba(117, 157, 255, 0) 34%),
    linear-gradient(180deg, #f5f8ff 0%, #f8faff 36%, #f3f6fb 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(214, 227, 255, 0.9);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 44rpx rgba(57, 107, 205, 0.08);
}

.header-card::before,
.section-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4c8dff 0%, #88bbff 55%, rgba(136, 187, 255, 0) 100%);
}

.hero-card {
  background:
    radial-gradient(circle at 84% 18%, rgba(133, 178, 255, 0.22) 0%, rgba(133, 178, 255, 0) 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(245, 249, 255, 0.98) 100%);
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(233, 241, 255, 0.92);
  border: 1rpx solid rgba(209, 225, 255, 0.94);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #5d7fc2;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #18253d;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.hint-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #6c7f9e;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2f4a;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #eff5ff 0%, #e1edff 100%);
  color: #4f77c7;
  font-size: 22rpx;
  font-weight: 700;
}

.template-picker-block {
  margin-bottom: 24rpx;
}

.template-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.template-picker-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #223553;
}

.template-picker-count {
  font-size: 22rpx;
  color: #7a8fb4;
}

.template-picker-scroll {
  width: 100%;
}

.template-picker-row {
  display: inline-flex;
  gap: 18rpx;
  padding-bottom: 8rpx;
}

.template-picker-card {
  width: 224rpx;
  flex-shrink: 0;
  padding: 14rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(210, 223, 249, 0.96);
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
  box-shadow: 0 8rpx 20rpx rgba(78, 121, 255, 0.06);
  box-sizing: border-box;
}

.template-picker-card.is-active {
  border-color: rgba(77, 126, 255, 0.9);
  box-shadow: 0 14rpx 28rpx rgba(78, 121, 255, 0.16);
  background: linear-gradient(180deg, #f4f8ff 0%, #e6efff 100%);
}

.template-picker-thumb {
  width: 100%;
  height: 224rpx;
  border-radius: 18rpx;
  background: #edf3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7b8fb2;
  font-size: 22rpx;
  text-align: center;
}

.template-picker-thumb.placeholder {
  border: 1rpx dashed rgba(176, 196, 233, 0.9);
}

.template-picker-name {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #213452;
  min-height: 72rpx;
}

.template-picker-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(77, 126, 255, 0.12);
  color: #5278c5;
  font-size: 20rpx;
  font-weight: 700;
}

.poster-stage {
  border-radius: 28rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #eef4ff 0%, #e5edff 100%);
  border: 1rpx solid rgba(123, 159, 255, 0.16);
  min-height: 680rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.poster-image,
.poster-placeholder {
  display: block;
  width: 100%;
}

.poster-placeholder {
  min-height: 680rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-placeholder-text {
  font-size: 28rpx;
  color: #8ba0c8;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
}

.primary-btn,
.secondary-btn {
  margin: 0;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 88rpx;
}

.primary-btn {
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(63, 125, 255, 0.18);
}

.secondary-btn {
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
  color: #4f77c7;
  border: 1rpx solid rgba(205, 220, 250, 0.92);
}

.poster-export-canvas {
  position: fixed;
  left: -99999px;
  top: -99999px;
  opacity: 0;
  pointer-events: none;
}
