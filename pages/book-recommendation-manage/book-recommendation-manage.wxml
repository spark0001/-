<view class="page">
  <view class="header-card" wx:if="{{loading}}">
    <view class="page-title">图书推荐管理</view>
    <view class="page-desc">正在加载图书推荐配置与数据...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="loadRecommendationData">重新加载</button>
  </view>

  <block wx:else>
    <view class="header-card">
      <view class="page-title">图书推荐管理</view>
      <view class="page-desc">这里用于维护首页图书推荐内容。可以新增推荐，也可以从下方列表载入已有推荐后直接编辑或删除。</view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view class="section-title">推荐数据</view>
        <view class="section-tag">去重统计</view>
      </view>

      <view class="stats-grid">
        <view class="stat-card">
          <view class="stat-value">{{stats.exposureCount}}</view>
          <view class="stat-label">曝光人数</view>
        </view>

        <view class="stat-card">
          <view class="stat-value">{{stats.clickCount}}</view>
          <view class="stat-label">点击人数</view>
        </view>

        <view class="stat-card">
          <view class="stat-value">{{stats.clickRateText}}</view>
          <view class="stat-label">点击率</view>
        </view>
      </view>
    </view>

    <view class="section-card">
      <view class="section-title">{{form._id ? '编辑推荐内容' : '新增推荐内容'}}</view>
      <view class="empty-text">
        {{form._id ? '当前正在编辑已有推荐，保存后会直接更新这条记录。' : '下方表单用于发布新一期推荐，不会覆盖旧推荐；也可以从下方列表点“编辑”载入已有内容后再保存。'}}
      </view>

      <view class="field-block">
        <view class="field-label">推荐标题</view>
        <input class="field-input" value="{{form.title}}" data-field="title" bindinput="onInput" placeholder="请输入推荐标题" />
      </view>

      <view class="field-block">
        <view class="field-label">推荐简介</view>
        <textarea class="field-textarea" value="{{form.summary}}" data-field="summary" bindinput="onInput" maxlength="200" placeholder="请输入推荐简介"></textarea>
      </view>

      <view class="field-block">
        <view class="field-label">公众号文章链接</view>
        <input class="field-input" value="{{form.articleUrl}}" data-field="articleUrl" bindinput="onInput" placeholder="请输入公众号文章链接" />
      </view>

      <view class="field-block">
        <view class="field-label">推荐封面图（可选）</view>

        <image class="cover-preview" wx:if="{{form.coverUrl}}" src="{{form.coverUrl}}" mode="aspectFill"></image>
        <view class="cover-placeholder" wx:else>当前还没有推荐封面图</view>

        <view class="action-row">
          <button class="action-btn" bindtap="onChooseCoverTap" disabled="{{uploadingCover}}">
            {{uploadingCover ? '上传中...' : '上传封面图'}}
          </button>
          <button class="action-btn light" bindtap="onClearCoverTap" disabled="{{!form.coverUrl}}">
            清除封面图
          </button>
        </view>
      </view>

      <view class="submit-row">
        <button class="save-btn" bindtap="onSaveTap" disabled="{{saving}}">
          {{saving ? (form._id ? '保存中...' : '发布中...') : (form._id ? '保存推荐修改' : '发布新推荐')}}
        </button>
        <button class="save-btn danger-btn" wx:if="{{form._id}}" bindtap="onDeleteRecommendationTap">
          删除该推荐
        </button>
      </view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view class="section-title">图书推荐列表</view>
        <view class="section-tag" bindtap="goRecommendationList">查看更多</view>
      </view>

      <view class="empty-text" wx:if="{{!recommendationPreviewList.length}}">
        当前还没有历史推荐记录，保存新的推荐内容后会保留在这里。
      </view>

      <view class="recommendation-list" wx:else>
        <view class="recommendation-item" wx:for="{{recommendationPreviewList}}" wx:key="_id">
          <image class="recommendation-item-cover" wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view class="recommendation-item-cover placeholder" wx:else>推荐封面</view>

          <view class="recommendation-item-main">
            <view class="recommendation-item-top">
              <view class="recommendation-item-title">{{item.title}}</view>
              <view class="recommendation-item-tag {{item.isCurrent ? 'current' : ''}}">
                {{item.isCurrent ? '当前推荐' : '历史推荐'}}
              </view>
            </view>
            <view class="recommendation-item-summary">{{item.summaryText}}</view>
            <view class="recommendation-item-time">{{item.timeText}}</view>

            <view class="recommendation-item-actions">
              <view class="mini-btn" data-item="{{item}}" bindtap="onEditRecommendationTap">编辑</view>
              <view class="mini-btn mini-btn-danger" data-item="{{item}}" bindtap="onDeleteRecommendationTap">删除</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>

<privacy-reminder
  visible="{{privacyReminderVisible}}"
  title="{{privacyReminderTitle}}"
  contract-name="{{privacyContractName}}"
  intro-text="{{privacyIntroText}}"
  confirm-text="{{privacyConfirmText}}"
  cancel-text="{{privacyCancelText}}"
  bindagree="onPrivacyReminderAgree"
  binddisagree="onPrivacyReminderDisagree"
  bindviewcontract="onPrivacyReminderViewContract"
/>
