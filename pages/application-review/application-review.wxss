.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.text-content,
.info-value {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label,
.text-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  flex: 1;
  text-align: right;
}

.text-block {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.action-btn.approve {
  background: #222222;
  color: #ffffff;
}

.action-btn.reject {
  background: #f1f2f6;
  color: #333333;
}

button::after {
  border: none;
}
