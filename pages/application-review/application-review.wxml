<view class="page">
  <view class="header-card">
    <view class="page-title">成员申请审核</view>
    <view class="page-desc">普通管理员和 superAdmin 都可以查看并审核待审核申请。</view>
  </view>

  <view class="section-card" wx:if="{{loading}}">
    <view class="empty-text">正在加载待审核申请...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="empty-text">{{errorMessage}}</view>
  </view>

  <view class="section-card" wx:elif="{{!list.length}}">
    <view class="empty-text">当前没有待审核申请。</view>
  </view>

  <block wx:else>
    <view class="section-card" wx:for="{{list}}" wx:key="_id">
      <view class="section-title">{{item.name || '未填写姓名'}}</view>

      <view class="info-row">
        <view class="info-label">年级 / 专业</view>
        <view class="info-value">{{item.gradeMajor || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">联系方式</view>
        <view class="info-value">{{item.contact || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">提交时间</view>
        <view class="info-value">{{item.createdAtText}}</view>
      </view>

      <view class="text-block">
        <view class="text-label">申请理由</view>
        <view class="text-content">{{item.reason || '未填写'}}</view>
      </view>

      <view class="action-row">
        <button
          class="action-btn approve"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
          data-action="approve"
          bindtap="onReviewTap"
          disabled="{{reviewingId === item._id}}"
        >
          通过
        </button>
        <button
          class="action-btn reject"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
          data-action="reject"
          bindtap="onReviewTap"
          disabled="{{reviewingId === item._id}}"
        >
          拒绝
        </button>
      </view>
    </view>
  </block>
</view>
