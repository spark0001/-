.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.16), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.18), transparent 28%),
    linear-gradient(180deg, #f5f8ff 0%, #f7f9fc 32%, #f5f7fb 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.entry-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(219, 231, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, rgba(229, 239, 255, 0.92) 0%, rgba(255, 255, 255, 0.98) 48%, rgba(239, 247, 255, 0.96) 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(10rpx);
}

.hero-glow-one {
  width: 220rpx;
  height: 220rpx;
  right: -36rpx;
  top: -40rpx;
  background: rgba(77, 118, 255, 0.16);
}

.hero-glow-two {
  width: 150rpx;
  height: 150rpx;
  right: 120rpx;
  top: 28rpx;
  background: rgba(143, 182, 255, 0.2);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
}

.page-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 800;
  color: #17233d;
  margin-bottom: 12rpx;
}

.page-desc,
.entry-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #61708c;
}

.page-desc {
  position: relative;
  z-index: 1;
}

.hero-badge-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(221, 231, 250, 0.94);
  color: #4d5b7a;
  font-size: 23rpx;
  font-weight: 600;
}

.entry-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 250, 255, 0.98) 100%);
}

.entry-card-topline {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #8eb6ff 62%, rgba(142, 182, 255, 0.08) 100%);
}

.entry-card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 226, 255, 0.94);
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  font-size: 32rpx;
  font-weight: 700;
  color: #22406f;
  margin-bottom: 14rpx;
}

.entry-arrow-pill {
  flex-shrink: 0;
  min-width: 132rpx;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 16rpx 26rpx rgba(63, 125, 255, 0.22);
}

.entry-arrow-pill-text {
  font-size: 26rpx;
  font-weight: 700;
}

.entry-arrow {
  font-size: 30rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.92);
}
