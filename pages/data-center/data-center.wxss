.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f1f2f6;
  color: #667085;
}

.chip-row,
.metric-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dimension-chip,
.metric-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e5e7eb;
  font-size: 25rpx;
  line-height: 1.4;
  color: #667085;
  background: #ffffff;
}

.dimension-chip-active {
  background: #222222;
  color: #ffffff;
  border-color: #222222;
}

.metric-chip-active {
  font-weight: 600;
}

.metric-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.chart-shell {
  margin-top: 24rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 12rpx;
}

.funnel-chart-box {
  background: linear-gradient(180deg, #f4f7ff 0%, #fbfcff 100%);
  border: 1rpx solid #e6ecff;
  padding: 20rpx 12rpx;
}

.chart-canvas {
  width: 100%;
}

.conversion-summary {
  margin-top: 24rpx;
  background: #f7f9ff;
  border: 1rpx solid #e6ecff;
  border-radius: 18rpx;
  padding: 24rpx;
}

.conversion-summary-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #375dfb;
  margin-bottom: 16rpx;
}

.conversion-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.conversion-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}

.conversion-label {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #667085;
}

.conversion-value {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #2f5bff;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #111827;
}

.stat-label,
.rate-text,
.funnel-label,
.funnel-value,
.mode-meta,
.data-card-time {
  font-size: 24rpx;
  color: #6b7280;
}

.rate-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 18rpx;
}

.data-card {
  margin-top: 16rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.data-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.data-card-header-main {
  flex: 1;
  min-width: 0;
}

.data-card-title,
.mode-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.data-card-summary {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #667085;
}

.data-card-link {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #375dfb;
}

.funnel-list {
  margin-top: 18rpx;
}

.funnel-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.funnel-item:last-child {
  margin-bottom: 0;
}

.funnel-label {
  width: 150rpx;
  flex-shrink: 0;
}

.funnel-bar-shell {
  flex: 1;
  height: 28rpx;
  background: #eef2f7;
  border-radius: 999rpx;
  overflow: hidden;
}

.funnel-bar {
  height: 100%;
  border-radius: 999rpx;
}

.funnel-bar.stage-1 {
  background: #2f6df6;
}

.funnel-bar.stage-2 {
  background: #4d76ff;
}

.funnel-bar.stage-3 {
  background: #7ea0ff;
}

.funnel-value {
  width: 80rpx;
  text-align: right;
  color: #111827;
}

.mode-card {
  margin-top: 16rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 22rpx;
}

.poster-card {
  margin-top: 16rpx;
  background: #f8fafc;
  border-radius: 22rpx;
  padding: 22rpx;
}

.poster-overview-layout {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 18rpx;
}

.poster-overview-gallery-panel,
.poster-overview-funnel-panel {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.poster-overview-gallery-panel {
  width: 296rpx;
  flex-shrink: 0;
}

.poster-overview-funnel-panel {
  flex: 1;
  min-width: 0;
}

.poster-overview-panel-title,
.poster-card-funnel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.poster-overview-gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.poster-gallery-item {
  min-width: 0;
}

.poster-gallery-thumb {
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #eef4ff 0%, #f7fbff 100%);
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.12);
}

.poster-gallery-image,
.poster-gallery-placeholder {
  width: 100%;
  height: 100%;
}

.poster-gallery-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx;
  box-sizing: border-box;
}

.poster-gallery-placeholder-text {
  font-size: 20rpx;
  line-height: 1.4;
  text-align: center;
  color: #6b7da8;
}

.poster-gallery-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #667085;
  word-break: break-all;
}

.poster-gallery-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
  margin-top: 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #eef4ff 0%, #f7fbff 100%);
  font-size: 24rpx;
  color: #6b7280;
}

.poster-summary-funnel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.poster-summary-funnel-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.poster-summary-funnel-shell {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.poster-summary-funnel-shape {
  min-width: 132rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 18rpx 999rpx 999rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #ffffff;
}

.poster-summary-funnel-value {
  width: 72rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.poster-card-content {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-top: 18rpx;
}

.poster-card-preview-shell {
  width: 198rpx;
  height: 304rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(180deg, #eef4ff 0%, #f7fbff 100%);
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.12);
}

.poster-card-preview,
.poster-card-preview-placeholder {
  width: 100%;
  height: 100%;
}

.poster-card-preview-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}

.poster-card-preview-text {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
  color: #6b7da8;
}

.poster-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.poster-card-funnel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.poster-card-funnel-tip {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  font-size: 22rpx;
  color: #375dfb;
}

.poster-card-funnel-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.poster-card-funnel-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.poster-card-funnel-label {
  width: 94rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #6b7280;
}

.poster-card-funnel-bar-shell {
  flex: 1;
  height: 28rpx;
  border-radius: 999rpx;
  background: #e8edf6;
  overflow: hidden;
}

.poster-card-funnel-bar {
  height: 100%;
  border-radius: 999rpx;
}

.poster-card-funnel-value {
  width: 60rpx;
  flex-shrink: 0;
  text-align: right;
  font-size: 24rpx;
  color: #111827;
}

.poster-card-meta {
  margin-top: 18rpx;
}

button::after {
  border: none;
}
