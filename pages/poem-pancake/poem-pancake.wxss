.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.18), transparent 28%),
    linear-gradient(180deg, #f5f8ff 0%, #f7f9fc 32%, #f5f7fb 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(219, 231, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, rgba(229, 239, 255, 0.94) 0%, rgba(255, 255, 255, 0.98) 48%, rgba(239, 247, 255, 0.98) 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(10rpx);
}

.hero-glow-one {
  width: 220rpx;
  height: 220rpx;
  right: -36rpx;
  top: -40rpx;
  background: rgba(77, 118, 255, 0.16);
}

.hero-glow-two {
  width: 150rpx;
  height: 150rpx;
  right: 120rpx;
  top: 28rpx;
  background: rgba(143, 182, 255, 0.2);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
}

.hero-title-row,
.card-top,
.enter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.page-title {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 800;
  color: #17233d;
  margin-bottom: 12rpx;
}

.hero-floating-tag,
.status-pill,
.meta-pill {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-weight: 700;
}

.hero-floating-tag {
  padding: 10rpx 18rpx;
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  font-size: 22rpx;
}

.page-desc,
.theme-text,
.enter-tip {
  font-size: 27rpx;
  line-height: 1.7;
  color: #63728d;
}

.hero-stat-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-stat-card {
  min-height: 118rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(220, 230, 250, 0.94);
}

.hero-stat-card-primary {
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
}

.hero-stat-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #1b325f;
}

.hero-stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7082a2;
  font-weight: 600;
}

.hero-stat-card-primary .hero-stat-value,
.hero-stat-card-primary .hero-stat-label {
  color: #ffffff;
}

.sync-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7f99;
}

.section-topline {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4d76ff 0%, #8eb6ff 62%, rgba(142, 182, 255, 0.08) 100%);
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 226, 255, 0.94);
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  font-size: 30rpx;
  font-weight: 700;
  color: #22406f;
}

.status-pill {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
}

.status-published {
  background: rgba(77, 118, 255, 0.12);
  color: #3f68ea;
}

.status-closed {
  background: rgba(226, 232, 240, 0.8);
  color: #516174;
}

.status-draft {
  background: rgba(254, 243, 199, 0.88);
  color: #b45309;
}

.status-archived {
  background: rgba(241, 245, 249, 0.96);
  color: #64748b;
}

.theme-text {
  margin-top: 18rpx;
  color: #385789;
  font-weight: 600;
}

.meta-row,
.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 10rpx 18rpx;
  background: rgba(240, 246, 255, 0.96);
  border: 1rpx solid rgba(221, 231, 250, 0.95);
  color: #5d6d88;
  font-size: 23rpx;
}

.stats-item {
  font-size: 24rpx;
  color: #566985;
  font-weight: 600;
}

.enter-row {
  margin-top: 20rpx;
  align-items: flex-start;
}

.enter-link {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #4d76ff;
  font-weight: 700;
}
