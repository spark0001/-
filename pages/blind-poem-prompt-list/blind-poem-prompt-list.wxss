.page {
  padding: 24rpx;
  background: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2937;
}

.page-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
}

.mode-tab-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mode-tab {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
}

.mode-tab-active {
  background: #111827;
  color: #ffffff;
}

.dense-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dense-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 96rpx;
  align-items: flex-start;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
  overflow: hidden;
}

.dense-main {
  flex: 1;
  min-width: 0;
}

.dense-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.dense-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.dense-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4b5563;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dense-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.dense-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 96rpx;
}

.mini-btn {
  width: 96rpx;
  min-width: 96rpx;
  box-sizing: border-box;
  height: 52rpx;
  line-height: 52rpx;
  border-radius: 10rpx;
  background: #111827;
  color: #ffffff;
  font-size: 20rpx;
  padding: 0;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-btn.light {
  background: #f3f4f6;
  color: #111827;
}

.mini-btn-disabled {
  opacity: 0.5;
}

.prompt-status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.prompt-status.enabled {
  background: #dcfce7;
  color: #15803d;
}

.prompt-status.disabled {
  background: #f3f4f6;
  color: #6b7280;
}

.action-btn {
  margin-top: 20rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #222222;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
}
