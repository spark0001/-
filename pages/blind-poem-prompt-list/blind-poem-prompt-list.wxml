<view class="page">
  <view class="section-card" wx:if="{{loading}}">
    <view class="page-title">题库列表</view>
    <view class="page-desc">正在加载题库详情...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="page-title">加载失败</view>
    <view class="page-desc">{{errorMessage}}</view>
    <button class="action-btn" bindtap="loadPromptList">重新加载</button>
  </view>

  <block wx:else>
    <view class="section-card">
      <view class="page-title">题库列表</view>
      <view class="page-desc">按模式切换查看完整题库，并在右侧直接编辑或启停题面。</view>
      <view class="mode-tab-row">
        <view
          class="mode-tab {{activeMode === item.value ? 'mode-tab-active' : ''}}"
          wx:for="{{modeOptions}}"
          wx:key="value"
          data-mode="{{item.value}}"
          bindtap="onModeChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="dense-list" wx:if="{{filteredPromptList.length}}">
      <view class="dense-item" wx:for="{{filteredPromptList}}" wx:key="promptId">
        <view class="dense-main">
          <view class="dense-top">
            <view class="dense-title">{{item.title || '未命名题面'}}</view>
            <view class="prompt-status {{item.status}}">{{item.statusText}}</view>
          </view>
          <view class="dense-desc">{{item.promptText}}</view>
          <view class="dense-meta">
            <text>排序：{{item.sort}}</text>
            <text wx:if="{{item.theme}}"> · 主题：{{item.theme}}</text>
            <text wx:if="{{item.imageryText}}"> · 意象：{{item.imageryText}}</text>
          </view>
        </view>

        <view class="dense-actions">
          <view class="mini-btn" bindtap="onEditPromptTap" data-id="{{item.promptId}}">编辑</view>
          <view class="mini-btn light {{updatingPromptId === item.promptId ? 'mini-btn-disabled' : ''}}" bindtap="onTogglePromptStatusTap" data-prompt="{{item}}">
            {{item.status === 'enabled' ? '停用' : '启用'}}
          </view>
        </view>
      </view>
    </view>

    <view class="section-card" wx:else>
      <view class="page-desc">当前模式下还没有题面。</view>
    </view>
  </block>
</view>
