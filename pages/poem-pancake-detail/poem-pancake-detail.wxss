.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(77, 118, 255, 0.18), transparent 34%),
    radial-gradient(circle at top right, rgba(143, 182, 255, 0.16), transparent 28%),
    linear-gradient(180deg, #f5f8ff 0%, #f7f9fc 32%, #f5f7fb 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(219, 231, 255, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(44, 74, 155, 0.08);
}

.hero-card {
  background: linear-gradient(135deg, rgba(229, 239, 255, 0.94) 0%, rgba(255, 255, 255, 0.98) 48%, rgba(239, 247, 255, 0.98) 100%);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(10rpx);
}

.hero-glow-one {
  width: 220rpx;
  height: 220rpx;
  right: -36rpx;
  top: -40rpx;
  background: rgba(77, 118, 255, 0.16);
}

.hero-glow-two {
  width: 150rpx;
  height: 150rpx;
  right: 120rpx;
  top: 28rpx;
  background: rgba(143, 182, 255, 0.2);
}

.hero-kicker {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(77, 118, 255, 0.1);
  color: #4d76ff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
}

.hero-top,
.section-head,
.action-row,
.editor-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #17233d;
  margin-bottom: 12rpx;
}

.page-desc,
.action-tip,
.editor-desc {
  font-size: 27rpx;
  line-height: 1.7;
  color: #63728d;
}

.status-pill,
.meta-pill,
.action-button,
.section-link {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.status-pill {
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-published {
  background: rgba(77, 118, 255, 0.12);
  color: #3f68ea;
}

.status-closed {
  background: rgba(226, 232, 240, 0.8);
  color: #516174;
}

.status-draft {
  background: rgba(254, 243, 199, 0.88);
  color: #b45309;
}

.status-archived {
  background: rgba(241, 245, 249, 0.96);
  color: #64748b;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.meta-pill {
  padding: 10rpx 18rpx;
  background: rgba(240, 246, 255, 0.96);
  border: 1rpx solid rgba(221, 231, 250, 0.95);
  color: #5d6d88;
  font-size: 23rpx;
  font-weight: 600;
}

.stat-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-card {
  min-height: 118rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(220, 230, 250, 0.94);
}

.stat-card-primary {
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #1b325f;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7082a2;
  font-weight: 600;
}

.stat-card-primary .stat-value,
.stat-card-primary .stat-label {
  color: #ffffff;
}

.action-row {
  margin-top: 22rpx;
  align-items: flex-start;
}

.action-tip {
  flex: 1;
  min-width: 0;
}

.action-button {
  min-width: 180rpx;
  padding: 18rpx 22rpx;
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 26rpx rgba(63, 125, 255, 0.22);
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 226, 255, 0.94);
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  font-size: 30rpx;
  font-weight: 700;
  color: #22406f;
}

.section-link {
  font-size: 24rpx;
  color: #88acef;
}

.board-scroll {
  width: 100%;
  max-height: 980rpx;
  margin-top: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #eef3ff 0%, #f8fbff 100%);
  border: 1rpx solid #e0eaff;
}

.board {
  padding: 18rpx;
  box-sizing: border-box;
}

.board-row {
  display: flex;
}

.board-cell {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(182, 197, 230, 0.85);
  border-bottom: 1rpx solid rgba(182, 197, 230, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.84);
}

.board-row:first-child .board-cell {
  border-top: 1rpx solid rgba(182, 197, 230, 0.85);
}

.board-cell:first-child {
  border-left: 1rpx solid rgba(182, 197, 230, 0.85);
}

.board-cell.is-filled {
  background: rgba(240, 246, 255, 0.98);
}

.board-cell.is-mine {
  background: linear-gradient(180deg, #dfe9ff 0%, #eef4ff 100%);
  box-shadow: inset 0 0 0 2rpx rgba(77, 118, 255, 0.18);
}

.board-cell.is-reserved {
  background: linear-gradient(180deg, #f0f4ff 0%, #dfe7ff 100%);
}

.board-cell.is-reserved-mine {
  background: linear-gradient(180deg, #e8f1ff 0%, #d6e5ff 100%);
}

.board-cell.is-editing {
  background: linear-gradient(180deg, #fff7d6 0%, #fff0b3 100%);
  box-shadow: inset 0 0 0 2rpx rgba(244, 180, 0, 0.32);
}

.board-cell-content {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e2f4d;
}

.board-cell-input {
  width: 100%;
  height: 100%;
  border: 0;
  padding: 0;
  margin: 0;
  background: transparent;
  font-size: 28rpx;
  font-weight: 700;
  color: #1e2f4d;
  text-align: center;
  line-height: 56rpx;
  box-sizing: border-box;
}

.board-cell-placeholder {
  color: rgba(30, 47, 77, 0.45);
  font-size: 28rpx;
  text-align: center;
}

.board-cell-reserve-text {
  font-size: 16rpx;
  font-weight: 700;
  color: #4d76ff;
  line-height: 1.2;
  text-align: center;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(18, 28, 52, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 999;
}

.editor-dialog {
  width: 100%;
  max-width: 620rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 34rpx;
  box-sizing: border-box;
}

.editor-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #17233d;
}

.editor-desc {
  margin-top: 12rpx;
}

.editor-input {
  margin-top: 24rpx;
  height: 92rpx;
  border-radius: 22rpx;
  background: #f5f8ff;
  border: 1rpx solid #dfe9ff;
  padding: 0 24rpx;
  font-size: 34rpx;
  color: #1f2f4a;
}

.editor-action-row {
  margin-top: 26rpx;
}

.editor-button {
  flex: 1;
  min-height: 92rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.button-light {
  background: #f0f4ff;
  color: #5d6d88;
}

.button-strong {
  background: linear-gradient(145deg, #4d86ff 0%, #315fe3 100%);
  color: #ffffff;
}
