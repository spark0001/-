.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.filter-card {
  padding: 22rpx 24rpx;
}

.filter-summary-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  margin-bottom: 18rpx;
}

.filter-summary {
  font-size: 24rpx;
  color: #667085;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f7f8fa;
  border-radius: 18rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.search-prefix {
  font-size: 24rpx;
  color: #98a2b3;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 26rpx;
  color: #222222;
}

.search-clear {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #667085;
  padding: 12rpx 0 12rpx 12rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.2;
  gap: 10rpx;
}

.filter-chip.active {
  background: #222222;
  color: #ffffff;
}

.filter-chip-count {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  background: #e4e7ec;
  color: #475467;
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
  box-sizing: border-box;
}

.filter-chip.active .filter-chip-count {
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.meta-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 12rpx;
}

.meta-text {
  font-size: 25rpx;
}

.field-row,
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.field-label,
.switch-label {
  font-size: 27rpx;
  color: #333333;
}

.picker-field {
  min-width: 220rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 26rpx;
  color: #222222;
}

.save-btn {
  margin-top: 24rpx;
  background: #222222;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

button::after {
  border: none;
}
