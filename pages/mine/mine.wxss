.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(115, 169, 255, 0.18) 0%, rgba(115, 169, 255, 0) 38%),
    linear-gradient(180deg, #f5f9ff 0%, #f7f9fd 42%, #f3f6fb 100%);
  padding: 24rpx;
  padding-bottom: 180rpx;
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-card,
.section-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(214, 227, 255, 0.88);
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 18rpx 44rpx rgba(57, 107, 205, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.94);
}

.header-card::before,
.section-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #4c8dff 0%, #88bbff 55%, rgba(136, 187, 255, 0) 100%);
}

.header-card {
  background:
    radial-gradient(circle at top right, rgba(130, 177, 255, 0.2) 0%, rgba(130, 177, 255, 0) 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 250, 255, 0.98) 100%);
}

.profile-hero-card {
  background:
    linear-gradient(135deg, rgba(248, 251, 255, 0.98) 0%, rgba(232, 242, 255, 0.98) 50%, rgba(255, 255, 255, 0.98) 100%);
  border-color: rgba(202, 220, 255, 0.94);
  box-shadow:
    0 22rpx 52rpx rgba(44, 92, 188, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.profile-hero-card::after {
  display: none;
}

.profile-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(10rpx);
}

.profile-glow-one {
  width: 220rpx;
  height: 220rpx;
  right: -40rpx;
  top: -40rpx;
  background: rgba(77, 118, 255, 0.16);
}

.profile-glow-two {
  width: 150rpx;
  height: 150rpx;
  right: 120rpx;
  top: 24rpx;
  background: rgba(143, 182, 255, 0.18);
}

.clickable-card {
  transition: transform 0.2s ease;
}

.manage-section {
  padding-top: 30rpx;
}

.manage-section::before {
  height: 10rpx;
  background: linear-gradient(90deg, #4c8dff 0%, #88bbff 55%, rgba(136, 187, 255, 0) 100%);
}

.section-hint {
  font-size: 24rpx;
  line-height: 1.8;
  color: #8394b2;
  margin-top: 12rpx;
  margin-bottom: 18rpx;
}

.entry-card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.entry-card-main {
  flex: 1;
}

.entry-card-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #7290c8;
  margin-top: 10rpx;
}

.entry-card-arrow {
  font-size: 36rpx;
  line-height: 1;
  color: #8caef0;
}

.settings-group {
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #e4edff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(210, 224, 250, 0.82);
}

.settings-row.no-border {
  border-bottom: none;
}

.settings-row-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.settings-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #e5f0ff 0%, #d6e8ff 100%);
  color: #2a67dd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.settings-row-main {
  flex: 1;
  min-width: 0;
}

.settings-row-title {
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #1f2f4a;
}

.settings-row-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #89a0c4;
}

.settings-row-arrow {
  font-size: 34rpx;
  line-height: 1;
  color: #89abef;
  flex-shrink: 0;
}

.profile-row {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(247, 251, 255, 0.76) 100%);
  border: 1rpx solid rgba(217, 229, 251, 0.92);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.96),
    0 12rpx 28rpx rgba(80, 124, 210, 0.1);
}

.avatar-box {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 28rpx rgba(32, 90, 189, 0.14);
}

.avatar-box.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #4c8dff 0%, #196fff 100%);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(25, 111, 255, 0.24);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.profile-main {
  flex: 1;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #18253d;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6c7f9e;
}

.profile-signature {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #324562;
}

.profile-signature.muted {
  color: #9cacbf;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
  position: relative;
  z-index: 1;
}

.status-badge,
.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
}

.status-badge.light,
.section-tag {
  background: linear-gradient(135deg, #f1f6ff 0%, #e4efff 100%);
  color: #4f77c7;
}

.status-badge.neutral {
  background: #eef1f5;
  color: #667085;
}

.status-badge.pending {
  background: #fff4e5;
  color: #a15c00;
}

.status-badge.approved {
  background: #e8f7ef;
  color: #1f8f55;
}

.status-badge.rejected {
  background: #fdecec;
  color: #b42318;
}

.meta-row,
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(225, 234, 247, 0.88);
}

.meta-row {
  margin-top: 20rpx;
  padding-top: 24rpx;
  padding-bottom: 0;
  position: relative;
  z-index: 1;
}

.meta-label,
.info-label,
.text-label {
  font-size: 26rpx;
  color: #7f92af;
}

.meta-value,
.info-value {
  flex: 1;
  text-align: right;
  font-size: 27rpx;
  line-height: 1.6;
  color: #1f2f4a;
}

.no-border {
  border-bottom: none;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.profile-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.profile-kicker {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(233, 241, 255, 0.92);
  border: 1rpx solid rgba(209, 225, 255, 0.94);
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: #5d7fc2;
  font-weight: 700;
}

.header-sync-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
}

.header-sync-status.is-ready {
  background: rgba(230, 244, 255, 0.96);
  color: #2a67dd;
  box-shadow: 0 8rpx 18rpx rgba(42, 103, 221, 0.08);
}

.header-sync-status.is-loading {
  background: rgba(243, 248, 255, 0.96);
  color: #6f8dca;
}

.sync-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(242, 247, 255, 0.95);
  border: 1rpx solid rgba(221, 232, 250, 0.92);
  font-size: 23rpx;
  line-height: 1.7;
  color: #7d8fae;
  position: relative;
  z-index: 1;
}

.sync-tip.error {
  background: rgba(255, 247, 237, 0.96);
  border-color: rgba(252, 221, 183, 0.94);
  color: #b96b14;
}

.reading-section-header {
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  padding: 12rpx 22rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid rgba(211, 225, 255, 0.92);
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  font-size: 32rpx;
  font-weight: 700;
  color: #22406f;
}

.reading-view-switch {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #e2ecff 100%);
  border: 1rpx solid #d8e5ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  flex-shrink: 0;
}

.reading-view-option {
  min-width: 90rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #5c82df;
}

.reading-view-option.active {
  background: #ffffff;
  color: #1677ff;
  box-shadow: 0 8rpx 18rpx rgba(22, 119, 255, 0.16);
}

.text-block {
  background: linear-gradient(180deg, #f8fbff 0%, #f1f6ff 100%);
  border: 1rpx solid #e3edff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
}

.text-block.compact {
  padding: 20rpx;
}

.text-content {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #324562;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.reading-stats-grid {
  margin-bottom: 24rpx;
}

.stat-card {
  width: calc((100% - 32rpx) / 3);
  background: linear-gradient(180deg, #fafcff 0%, #f2f7ff 100%);
  border: 1rpx solid #e2ebff;
  border-radius: 22rpx;
  padding: 24rpx 16rpx;
  box-sizing: border-box;
  text-align: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.reading-stat-card {
  background: linear-gradient(180deg, #fbfdff 0%, #f1f7ff 100%);
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 10rpx;
}

.reading-stat-value {
  color: #1677ff;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.reading-stat-label {
  color: #6f8dca;
}

.progress-box {
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border: 1rpx solid #e2ecff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.reading-progress-box {
  margin-bottom: 24rpx;
}

.progress-rule {
  font-size: 26rpx;
  line-height: 1.7;
  color: #52698f;
  margin-bottom: 14rpx;
}

.progress-main {
  font-size: 30rpx;
  color: #1d2f52;
  margin-bottom: 12rpx;
}

.progress-meta {
  font-size: 24rpx;
  color: #7a95c6;
  margin-bottom: 12rpx;
}

.progress-sub {
  font-size: 26rpx;
  color: #637694;
  line-height: 1.7;
}

.highlight {
  font-weight: 700;
  color: #1677ff;
}

.success-text {
  color: #1f8f55;
  font-weight: 600;
}

.reading-visual-card {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid #e4edff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(36, 96, 214, 0.06);
  margin-bottom: 24rpx;
}

.visual-title {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #173258;
}

.visual-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  flex-wrap: wrap;
}

.visual-heading {
  flex: 1;
  min-width: 0;
}

.visual-subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #94a6c2;
}

.visual-view-switch {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #e2ecff 100%);
  border: 1rpx solid #d8e5ff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  flex-shrink: 0;
}

.visual-view-option {
  min-width: 86rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #5c82df;
}

.visual-view-option.active {
  background: #ffffff;
  color: #1677ff;
  box-shadow: 0 8rpx 18rpx rgba(22, 119, 255, 0.16);
}

.reading-bar-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 260rpx;
  margin-top: 30rpx;
}

.reading-bar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reading-bar-stage {
  width: 100%;
  min-height: 220rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.reading-bar-fill {
  width: 100%;
  max-width: 82rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 10rpx 8rpx;
}

.reading-bar-fill.empty {
  max-width: 72rpx;
  background: #d9dde5;
  border-radius: 999rpx;
  padding: 0;
}

.reading-bar-fill.level-1 {
  background: linear-gradient(180deg, #c7dcff 0%, #9abfff 100%);
}

.reading-bar-fill.level-2 {
  background: linear-gradient(180deg, #9cc0ff 0%, #6fa5ff 100%);
}

.reading-bar-fill.level-3 {
  background: linear-gradient(180deg, #6ca5ff 0%, #3a84ff 100%);
}

.reading-bar-fill.level-4 {
  background: linear-gradient(180deg, #4f93ff 0%, #1677ff 100%);
}

.reading-bar-fill.today {
  background: linear-gradient(180deg, #3f8cff 0%, #005cff 100%);
  box-shadow: 0 14rpx 28rpx rgba(22, 119, 255, 0.22);
}

.reading-bar-fill.today-empty {
  max-width: 72rpx;
  background: linear-gradient(180deg, #4f93ff 0%, #1677ff 100%);
  border-radius: 999rpx;
  padding: 0;
  box-shadow: 0 10rpx 20rpx rgba(22, 119, 255, 0.2);
}

.reading-bar-text {
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
}

.reading-bar-day {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #8b93a1;
}

.reading-bar-day.today {
  color: #1677ff;
  font-weight: 700;
}

.reading-chart-meta {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.reading-chart-meta-item {
  font-size: 28rpx;
  line-height: 1.6;
  color: #98a2b3;
}

.reading-chart-meta-highlight {
  color: #1ea6ff;
  font-weight: 700;
}

.monthly-favorite-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 16rpx;
  margin-top: 28rpx;
}

.monthly-favorite-grid.annual-mode {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 20rpx 16rpx;
}

.monthly-favorite-grid.annual-mode .monthly-favorite-item {
  width: auto;
  min-width: 0;
}

.monthly-favorite-item {
  width: calc((100% - 80rpx) / 6);
  min-width: 96rpx;
}

.favorite-focus-card {
  margin-top: 28rpx;
  min-height: 240rpx;
  border-radius: 28rpx;
  border: 1rpx solid #e4edff;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
}

.favorite-focus-card.filled {
  box-shadow: 0 16rpx 32rpx rgba(79, 131, 255, 0.18);
}

.favorite-focus-card.placeholder {
  border-style: dashed;
}

.favorite-focus-month {
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2f6dff;
}

.favorite-focus-caption {
  margin-top: 26rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.88);
}

.favorite-focus-title {
  margin-top: 14rpx;
  font-size: 36rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #ffffff;
}

.favorite-focus-duration {
  margin-top: 24rpx;
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.36);
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.favorite-focus-placeholder-icon {
  margin-top: 26rpx;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 700;
  color: #98a2b3;
}

.favorite-focus-placeholder-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #98a2b3;
}

.monthly-favorite-cover {
  height: 156rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid #edf2ff;
  background: #f2f4f8;
}

.monthly-favorite-cover.filled {
  box-shadow: 0 10rpx 20rpx rgba(79, 131, 255, 0.15);
}

.monthly-favorite-cover.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef2f7 100%);
}

.monthly-favorite-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 14rpx 12rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.06) 0%, rgba(15, 23, 42, 0.55) 100%);
}

.monthly-favorite-title {
  font-size: 23rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #ffffff;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.monthly-favorite-duration {
  align-self: flex-start;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.42);
  font-size: 22rpx;
  line-height: 1.2;
  color: #ffffff;
}

.monthly-favorite-placeholder-icon {
  font-size: 36rpx;
  font-weight: 700;
  color: #98a2b3;
}

.monthly-favorite-month {
  margin-top: 12rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.4;
  color: #8b93a1;
}

.heatmap-month-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 16rpx;
  margin-top: 28rpx;
}

.heatmap-focus-card {
  margin-top: 28rpx;
  position: relative;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #f2f7ff 100%);
  border: 1rpx solid #e4edff;
}

.heatmap-focus-label {
  margin-bottom: 18rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #5c82df;
  padding-right: 220rpx;
}

.heatmap-detail-popover {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  max-width: 220rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 32rpx rgba(79, 131, 255, 0.18);
  border: 1rpx solid #d9e7ff;
  z-index: 2;
}

.heatmap-detail-date {
  font-size: 22rpx;
  line-height: 1.4;
  color: #6b7280;
}

.heatmap-detail-duration {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1677ff;
}

.heatmap-weekday-row {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.heatmap-weekday {
  text-align: center;
  font-size: 22rpx;
  line-height: 1.4;
  color: #98a2b3;
}

.heatmap-calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
}

.heatmap-calendar-cell {
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  box-sizing: border-box;
  padding: 10rpx;
  border: 1rpx solid transparent;
  transition: all 0.2s ease;
}

.heatmap-calendar-cell.placeholder {
  background: transparent;
  border-color: transparent;
}

.heatmap-calendar-cell.selected {
  border-color: #3a84ff;
  box-shadow: 0 10rpx 20rpx rgba(58, 132, 255, 0.18);
}

.heatmap-calendar-day {
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
  color: #8b93a1;
}

.heatmap-calendar-cell.level-1 .heatmap-calendar-day,
.heatmap-calendar-cell.level-2 .heatmap-calendar-day {
  color: #3f5d9d;
}

.heatmap-calendar-cell.level-3 .heatmap-calendar-day,
.heatmap-calendar-cell.level-4 .heatmap-calendar-day {
  color: #ffffff;
}

.heatmap-month-card {
  width: calc((100% - 48rpx) / 4);
  min-width: 136rpx;
}

.heatmap-month-label {
  margin-bottom: 12rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.4;
  color: #667085;
}

.heatmap-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.heatmap-cell {
  width: calc((100% - 36rpx) / 7);
  height: 14rpx;
  border-radius: 6rpx;
  background: #eef2f7;
}

.heatmap-cell.placeholder,
.heatmap-cell.level-0 {
  background: #eef2f7;
}

.heatmap-cell.level-1 {
  background: #d8e8ff;
}

.heatmap-cell.level-2 {
  background: #a9cbff;
}

.heatmap-cell.level-3 {
  background: #6ca5ff;
}

.heatmap-cell.level-4 {
  background: #1677ff;
}

.heatmap-legend {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.heatmap-legend-label {
  font-size: 26rpx;
  line-height: 1.5;
  color: #8b93a1;
}

.heatmap-legend-scale {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.heatmap-cell.legend {
  width: 22rpx;
  height: 22rpx;
}

.heatmap-calendar-grid .heatmap-calendar-cell {
  width: auto;
  height: 68rpx;
  border-radius: 16rpx;
  padding: 10rpx;
}

.heatmap-calendar-grid .heatmap-calendar-cell.placeholder {
  background: transparent;
  border-color: transparent;
}

.subsection-title {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 184rpx;
  padding: 10rpx 18rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid rgba(214, 227, 255, 0.92);
  background: linear-gradient(135deg, #f2f7ff 0%, #e4efff 100%);
  font-size: 30rpx;
  font-weight: 700;
  color: #22406f;
  margin: 24rpx 0 16rpx;
}

.subsection-title.no-margin {
  margin: 0;
}

.subsection-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 24rpx 0 16rpx;
}

.subsection-link {
  font-size: 24rpx;
  line-height: 1.6;
  color: #89aef0;
  flex-shrink: 0;
}

.log-card,
.data-card {
  background: linear-gradient(180deg, #f9fbff 0%, #f1f6ff 100%);
  border: 1rpx solid #e4edff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.96);
}

.record-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f3f8ff 100%);
  border: 1rpx solid #e3edff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 12rpx 26rpx rgba(64, 111, 205, 0.06);
}

.clickable-record-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.record-card:last-child {
  margin-bottom: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.record-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.record-tag.reading {
  background: #eef3ff;
  color: #3559c7;
}

.record-tag.life {
  background: #edf8f1;
  color: #157347;
}

.record-time {
  font-size: 23rpx;
  line-height: 1.6;
  color: #98aac5;
  text-align: right;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #1e3256;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-summary {
  font-size: 26rpx;
  line-height: 1.7;
  color: #637694;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-enter-text {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7da4eb;
}

.record-thumb {
  width: 144rpx;
  height: 144rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #e9edf3;
  box-shadow: 0 10rpx 18rpx rgba(66, 102, 166, 0.08);
}

.data-card {
  margin-bottom: 18rpx;
}

.data-card:last-child {
  margin-bottom: 0;
}

.data-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2f4a;
  margin-bottom: 10rpx;
}

.data-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.data-card-header-main {
  flex: 1;
  min-width: 0;
}

.data-card-time {
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f85a8;
  margin-bottom: 18rpx;
}

.data-card-link {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #88acef;
}

.data-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.data-metric {
  width: calc((100% - 16rpx) / 2);
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid #e7efff;
  border-radius: 18rpx;
  padding: 20rpx 16rpx;
  box-sizing: border-box;
  text-align: center;
}

.data-metric-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #2a67dd;
  margin-bottom: 8rpx;
}

.data-metric-label {
  font-size: 24rpx;
  color: #7a8eae;
}

.rate-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.rate-item {
  flex: 1;
  min-width: 220rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid #e7efff;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  color: #4d6387;
}

.log-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2f4a;
  margin-bottom: 12rpx;
}

.log-meta {
  font-size: 25rpx;
  line-height: 1.7;
  color: #7084a4;
  margin-bottom: 6rpx;
}

.log-meta:last-of-type {
  margin-bottom: 0;
}

.empty-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #7084a4;
}

.secondary-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  color: #2b67dc;
  border-radius: 18rpx;
  border: 1rpx solid #d9e6ff;
  font-size: 28rpx;
  font-weight: 600;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  background: linear-gradient(135deg, #4f93ff 0%, #1677ff 100%);
  color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  box-shadow: 0 14rpx 24rpx rgba(22, 119, 255, 0.2);
}

.action-btn.light {
  background: linear-gradient(135deg, #eef5ff 0%, #dce9ff 100%);
  color: #2b67dc;
  box-shadow: none;
  border: 1rpx solid #d9e6ff;
}

.secondary-btn::after,
.action-btn::after {
  border: none;
}
