<view class="page">
  <view class="header-card">
    <view class="header-top">
      <view>
        <view class="page-title">图书推荐列表</view>
        <view class="page-desc">这里查看当前推荐和往期推荐内容，点击任一推荐即可进入对应文章。</view>
      </view>
      <view class="manage-badge" wx:if="{{canManage}}">管理可见</view>
    </view>

    <view class="overview-grid">
      <view class="overview-pill">
        <view class="overview-value">{{overview.totalCount}}</view>
        <view class="overview-label">全部推荐</view>
      </view>
      <view class="overview-pill">
        <view class="overview-value">{{overview.archiveCount}}</view>
        <view class="overview-label">往期内容</view>
      </view>
      <view class="overview-pill wide">
        <view class="overview-value small">{{overview.latestUpdateText}}</view>
        <view class="overview-label">最近更新</view>
      </view>
    </view>

    <view class="sync-tip" wx:if="{{syncing}}">后台正在静默刷新最新列表，你可以先继续浏览当前内容。</view>
  </view>

  <view class="section-card" wx:if="{{loading && !hasContent}}">
    <view class="empty-text">正在加载图书推荐列表...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="loadRecommendationList">重新加载</button>
  </view>

  <view class="recommendation-list" wx:elif="{{recommendationList.length}}">
    <view class="recommendation-card {{item.isCurrent ? 'current' : 'history'}}" wx:for="{{recommendationList}}" wx:key="_id" data-item="{{item}}" bindtap="onRecommendationTap">
      <view class="recommendation-cover-wrap">
        <image class="recommendation-cover" wx:if="{{item.coverUrl}}" src="{{item.coverUrl}}" mode="aspectFill" lazy-load="{{true}}"></image>
        <view class="recommendation-cover placeholder" wx:else>{{item.coverFallbackText}}</view>
        <view class="recommendation-seq">{{index + 1}}</view>
      </view>

      <view class="recommendation-main">
        <view class="recommendation-top">
          <view class="recommendation-heading">
            <view class="recommendation-title">{{item.title}}</view>
            <view class="recommendation-summary">{{item.summaryText}}</view>
          </view>
          <view class="recommendation-tag {{item.isCurrent ? 'current' : 'history'}}">
            {{item.badgeText}}
          </view>
        </view>

        <view class="recommendation-meta-row">
          <view class="recommendation-meta-pill">{{item.articleSourceText}}</view>
          <view class="recommendation-time">{{item.timeText}}</view>
        </view>

        <view class="recommendation-footer">
          <view class="recommendation-open-text">{{openingRecommendationId === item._id ? '正在打开...' : '点击查看全文'}}</view>

          <view class="recommendation-actions" wx:if="{{canManage}}">
            <view class="recommendation-action-btn" catchtap="onEditRecommendationTap" data-item="{{item}}">编辑</view>
            <view class="recommendation-action-btn danger" catchtap="onDeleteRecommendationTap" data-item="{{item}}">
              {{deletingRecommendationId === item._id ? '删除中...' : '删除'}}
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card" wx:else>
    <view class="empty-text">当前还没有推荐记录，管理员保存后会在这里展示。</view>
  </view>
</view>
