.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(96, 143, 255, 0.16), transparent 34%),
    linear-gradient(180deg, #f4f8ff 0%, #f8fbff 38%, #f5f7fb 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card,
.recommendation-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(219, 232, 255, 0.92);
  border-radius: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 48rpx rgba(47, 91, 182, 0.08);
}

.header-card,
.section-card {
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #173258;
}

.page-desc,
.empty-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #6881a7;
}

.manage-badge {
  flex-shrink: 0;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #edf4ff 0%, #dbe8ff 100%);
  color: #2d6bff;
  font-size: 22rpx;
  font-weight: 700;
}

.overview-grid {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.overview-pill {
  min-width: 0;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
  border: 1rpx solid #e1ecff;
}

.overview-pill.wide {
  grid-column: span 2;
}

.overview-value {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #173258;
}

.overview-value.small {
  font-size: 24rpx;
  line-height: 1.5;
}

.overview-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #86a0c5;
}

.sync-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(236, 244, 255, 0.95);
  color: #6282b7;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #173258;
  margin-bottom: 12rpx;
}

.secondary-btn {
  margin-top: 20rpx;
  background: linear-gradient(180deg, #f1f5fb 0%, #e6edf8 100%);
  color: #3a4b63;
  border-radius: 18rpx;
  font-size: 28rpx;
}

button::after {
  border: none;
}

.recommendation-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.recommendation-card {
  display: flex;
  gap: 22rpx;
  padding: 24rpx;
}

.recommendation-card.current {
  border-color: rgba(100, 143, 255, 0.95);
  box-shadow: 0 20rpx 54rpx rgba(57, 114, 255, 0.14);
}

.recommendation-card.history {
  border-color: rgba(224, 232, 245, 0.96);
}

.recommendation-cover-wrap {
  position: relative;
  width: 188rpx;
  height: 214rpx;
  flex-shrink: 0;
}

.recommendation-cover {
  width: 100%;
  height: 100%;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #eff4fb 0%, #e8eef8 100%);
}

.recommendation-cover.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #7d92b3;
  letter-spacing: 2rpx;
}

.recommendation-seq {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  min-width: 52rpx;
  height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.5);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 38rpx;
  text-align: center;
  box-sizing: border-box;
}

.recommendation-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recommendation-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.recommendation-heading {
  min-width: 0;
  flex: 1;
}

.recommendation-title {
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1d2f52;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommendation-tag {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.recommendation-tag.current {
  background: rgba(49, 183, 108, 0.14);
  color: #249458;
}

.recommendation-tag.history {
  background: rgba(54, 93, 179, 0.08);
  color: #7c8fac;
}

.recommendation-summary {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.75;
  color: #6f84a6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.recommendation-meta-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.recommendation-meta-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f6fd;
  color: #6a7f9f;
  font-size: 22rpx;
  line-height: 1.2;
}

.recommendation-time {
  font-size: 22rpx;
  line-height: 1.5;
  color: #97a6bc;
}

.recommendation-footer {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 20rpx;
}

.recommendation-open-text {
  min-width: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #2f6bff;
}

.recommendation-actions {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recommendation-action-btn {
  min-width: 102rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(47, 107, 255, 0.12);
  color: #2f6bff;
  font-size: 23rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.recommendation-action-btn.danger {
  background: rgba(31, 38, 51, 0.08);
  color: #334055;
}
