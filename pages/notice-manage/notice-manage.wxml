<view class="page">
  <view class="header-card" wx:if="{{loading}}">
    <view class="page-title">公告管理</view>
    <view class="page-desc">正在加载当前公告...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="loadNoticeData">重新加载</button>
  </view>

  <block wx:else>
    <view class="header-card">
      <view class="page-title">公告管理</view>
      <view class="page-desc">这里维护当前最新公告，并保留往期公告记录。前台始终只对最新公告做一次性弹窗提醒。</view>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view class="section-title">当前公告</view>
        <view class="section-tag {{currentNotice && currentNotice.isActive ? 'active' : ''}}">
          {{currentNotice ? (currentNotice.isActive ? '启用中' : '未启用') : '暂无公告'}}
        </view>
      </view>

      <block wx:if="{{currentNotice}}">
        <view class="notice-title">{{currentNotice.title}}</view>
        <view class="notice-content">{{currentNotice.content}}</view>
        <view class="notice-time">更新时间：{{currentNotice.updatedAtText}}</view>
      </block>
      <view class="empty-text" wx:else>当前还没有公告，保存后会立即成为最新公告。</view>
    </view>

    <view class="section-card">
      <view class="section-title">编辑公告</view>
      <view class="field-tip" wx:if="{{editingSourceNoticeId}}">当前正在基于“{{editingSourceTitle}}”编辑，保存后会生成新的最新公告。</view>

      <view class="field-block">
        <view class="field-label">公告标题</view>
        <input class="field-input" value="{{form.title}}" data-field="title" bindinput="onInput" placeholder="请输入公告标题" />
      </view>

      <view class="field-block">
        <view class="field-label">公告正文</view>
        <textarea class="field-textarea" value="{{form.content}}" data-field="content" bindinput="onInput" maxlength="500" placeholder="请输入公告正文"></textarea>
      </view>

      <view class="field-block">
        <view class="switch-row">
          <view class="field-label no-margin">启用公告</view>
          <switch checked="{{form.isActive}}" bindchange="onActiveChange" color="#222222" />
        </view>
        <view class="field-tip">关闭后，用户进入小程序时将不会弹出公告。</view>
      </view>

      <button class="save-btn" bindtap="onSaveTap" disabled="{{saving}}">
        {{saving ? '保存中...' : '保存公告'}}
      </button>
    </view>

    <view class="section-card">
      <view class="section-header">
        <view class="section-title">往期公告列表</view>
        <view class="section-tag">{{noticeHistoryList.length}} 条</view>
      </view>

      <block wx:if="{{noticeHistoryList.length}}">
        <view class="history-list">
          <view class="history-item" wx:for="{{noticeHistoryList}}" wx:key="noticeId">
            <view class="history-item-top">
              <view class="history-item-title">{{item.title}}</view>
              <view class="history-item-tags">
                <view class="section-tag active" wx:if="{{item.isLatest}}">当前公告</view>
                <view class="section-tag" wx:if="{{!item.isLatest}}">往期公告</view>
              </view>
            </view>
            <view class="history-item-summary">{{item.summary}}</view>
            <view class="history-item-meta">
              <view>{{item.updatedAtText}}</view>
              <view>{{item.isActive ? '已启用' : '未启用'}}</view>
            </view>
            <view class="history-item-actions">
              <view class="mini-btn" data-item="{{item}}" bindtap="onEditNoticeTap">编辑</view>
              <view
                class="mini-btn light {{updatingNoticeId === item.noticeId ? 'mini-btn-disabled' : ''}}"
                data-item="{{item}}"
                bindtap="onToggleNoticeStatusTap"
              >
                {{item.isActive ? '停用' : '启用'}}
              </view>
              <view
                class="mini-btn danger {{deletingNoticeId === item.noticeId ? 'mini-btn-disabled' : ''}}"
                data-item="{{item}}"
                bindtap="onDeleteNoticeTap"
              >
                {{deletingNoticeId === item.noticeId ? '删除中' : '删除'}}
              </view>
            </view>
          </view>
        </view>
      </block>

      <view class="empty-text" wx:else>当前还没有往期公告记录。</view>
    </view>
  </block>
</view>
