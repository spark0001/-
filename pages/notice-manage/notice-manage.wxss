.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.field-tip {
  font-size: 26rpx;
  line-height: 1.7;
  color: #666666;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f1f2f6;
  color: #666666;
  font-size: 24rpx;
}

.section-tag.active {
  background: rgba(64, 182, 106, 0.12);
  color: #2f9a56;
}

.notice-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 14rpx;
}

.notice-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333333;
  white-space: pre-wrap;
  margin-bottom: 16rpx;
}

.notice-time {
  font-size: 24rpx;
  color: #98a0ae;
}

.field-block {
  margin-top: 28rpx;
}

.field-label {
  font-size: 28rpx;
  color: #222222;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.field-label.no-margin {
  margin-bottom: 0;
}

.field-input,
.field-textarea {
  width: 100%;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #222222;
}

.field-input {
  height: 108rpx;
  line-height: 108rpx;
  padding: 0 28rpx;
}

.field-textarea {
  min-height: 220rpx;
  line-height: 1.7;
  padding: 28rpx 28rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.save-btn,
.secondary-btn {
  border-radius: 18rpx;
  font-size: 28rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.history-item {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 24rpx;
}

.history-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.history-item-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
}

.history-item-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.history-item-summary {
  font-size: 26rpx;
  line-height: 1.7;
  color: #555555;
  margin-bottom: 14rpx;
}

.history-item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  font-size: 24rpx;
  color: #98a0ae;
}

.history-item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 20rpx;
}

.mini-btn {
  min-width: 120rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #1f2633;
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.mini-btn.light {
  background: #f1f2f6;
  color: #333333;
}

.mini-btn.danger {
  background: #ffe9e9;
  color: #c53b3b;
}

.mini-btn-disabled {
  opacity: 0.5;
}

.save-btn {
  margin-top: 28rpx;
  background: #222222;
  color: #ffffff;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
}

button::after {
  border: none;
}
