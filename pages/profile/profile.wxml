<view class="page">
  <view class="header-card" wx:if="{{loading}}">
    <view class="page-title">用户资料</view>
    <view class="page-desc">正在加载正式用户资料...</view>
  </view>

  <view class="section-card" wx:elif="{{errorMessage}}">
    <view class="section-title">加载失败</view>
    <view class="empty-text">{{errorMessage}}</view>
    <button class="secondary-btn" bindtap="onRetryTap">重新加载</button>
  </view>

  <view class="section-card" wx:else>
    <view class="section-header">
      <view class="section-title">用户资料</view>
      <view class="section-tag">{{editing ? '编辑中' : '只读'}}</view>
    </view>

    <block wx:if="{{!editing}}">
      <view class="info-row">
        <view class="info-label">申请姓名</view>
        <view class="info-value">{{form.name || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">联系方式</view>
        <view class="info-value">{{form.contact || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">年级 / 专业</view>
        <view class="info-value">{{form.gradeMajor || '未填写'}}</view>
      </view>

      <view class="info-row">
        <view class="info-label">生日</view>
        <view class="info-value">{{form.birthday || '未填写'}}</view>
      </view>

      <view class="info-row no-border">
        <view class="info-label">个性签名</view>
        <view class="info-value">{{form.signature || '未填写'}}</view>
      </view>

      <button class="primary-btn" bindtap="onEditTap">编辑资料</button>
    </block>

    <block wx:else>
      <view class="form-item">
        <view class="field-label">申请姓名</view>
        <input
          class="input-field"
          value="{{form.name}}"
          placeholder="请输入姓名"
          data-field="name"
          bindinput="onFieldInput"
        />
      </view>

      <view class="form-item">
        <view class="field-label">联系方式</view>
        <input
          class="input-field"
          value="{{form.contact}}"
          placeholder="请输入联系方式"
          data-field="contact"
          bindinput="onFieldInput"
        />
      </view>

      <view class="form-item no-margin">
        <view class="field-label">年级 / 专业</view>
        <input
          class="input-field"
          value="{{form.gradeMajor}}"
          placeholder="请输入年级/专业"
          data-field="gradeMajor"
          bindinput="onFieldInput"
        />
      </view>

      <view class="form-item">
        <view class="field-label">生日</view>
        <picker mode="date" value="{{form.birthday}}" bindchange="onBirthdayChange">
          <view class="picker-field {{form.birthday ? '' : 'picker-placeholder'}}">
            {{form.birthday || '请选择生日'}}
          </view>
        </picker>
      </view>

      <view class="form-item no-margin">
        <view class="field-label">个性签名</view>
        <textarea
          class="textarea-field"
          value="{{form.signature}}"
          placeholder="写一句你的个性签名"
          data-field="signature"
          bindinput="onFieldInput"
          maxlength="50"
        />
      </view>

      <button class="primary-btn" bindtap="onSaveTap" disabled="{{saving}}">
        {{saving ? '保存中...' : '保存'}}
      </button>
    </block>
  </view>
</view>
