.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card,
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.page-desc,
.empty-text,
.info-value {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666666;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222222;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #f1f2f6;
  color: #333333;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label,
.field-label {
  font-size: 26rpx;
  color: #666666;
}

.info-value {
  flex: 1;
  text-align: right;
}

.no-border {
  border-bottom: none;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item.no-margin {
  margin-bottom: 0;
}

.field-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.input-field {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  margin-top: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f9fc;
  font-size: 28rpx;
  color: #222222;
}

.picker-field {
  width: 100%;
  margin-top: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f9fc;
  font-size: 28rpx;
  color: #222222;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  line-height: 1.5;
}

.picker-placeholder {
  color: #999999;
}

.textarea-field {
  width: 100%;
  min-height: 220rpx;
  margin-top: 0;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f8f9fc;
  font-size: 28rpx;
  color: #222222;
  line-height: 1.7;
}

.primary-btn {
  margin-top: 24rpx;
  background: #222222;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.secondary-btn {
  margin-top: 20rpx;
  background: #f1f2f6;
  color: #333333;
  border-radius: 16rpx;
  font-size: 28rpx;
}

button::after {
  border: none;
}
