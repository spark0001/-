.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 24rpx 18rpx;
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  pointer-events: none;
}

.tabbar-glass {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 16rpx 44rpx rgba(19, 31, 66, 0.16);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  pointer-events: auto;
}

.tabbar-item {
  flex: 1;
  min-width: 0;
}

.tabbar-item-inner {
  min-height: 100rpx;
  padding: 10rpx 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #2d3442;
  transition: all 0.2s ease;
}

.tabbar-item.is-active .tabbar-item-inner {
  background: rgba(47, 107, 255, 0.12);
  box-shadow: inset 0 0 0 1rpx rgba(47, 107, 255, 0.12);
  color: #2f6bff;
}

.tabbar-icon {
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

.tabbar-icon-text {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 600;
  color: inherit;
}

.tabbar-text {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 600;
  color: inherit;
  white-space: nowrap;
}
